# Copia para .env.deploy (ficheiro ignorado pelo Git) e preenche.
# NUNCA coloques senhas da Hostinger/Vercel aqui — usa chave SSH + token.

# IP ou hostname do VPS (Hostinger)
DEPLOY_HOST=

# Utilizador SSH (ex.: root ou u123456789)
DEPLOY_USER=

# Pasta no servidor onde está o clone do repositório
DEPLOY_PATH=/var/www/erp-ads-ativos

# Caminho local da chave privada SSH (Windows: C:/Users/.../.ssh/id_ed25519)
DEPLOY_SSH_KEY_PATH=

# Nome do processo no PM2 (igual ao usado no servidor)
DEPLOY_PM2_NAME=erp-ads-ativos
