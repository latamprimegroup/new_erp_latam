# ── Kast / Cripto — Pagamento em Stablecoins USDT/USDC (NOWPayments) ────────
# Engine: NOWPayments (nowpayments.io) — provider público com API completa
# Criar conta em: https://nowpayments.io → API Keys → Generate API Key
NOWPAYMENTS_API_KEY=""
# IPN Secret: NOWPayments Dashboard → Settings → Payments → IPN Secret Key
# Configurar IPN URL: https://seu-dominio.com/api/webhooks/kast
NOWPAYMENTS_IPN_SECRET=""
# Moeda de recebimento padrão (TRON é mais barato em gas, ~$0.50/tx)
# Opções: usdttrc20 | usdterc20 | usdtbsc | usdtpoly | usdcsol | usdcerc20
NOWPAYMENTS_CURRENCY="usdttrc20"

# ── Mercury Bank — Operação Internacional USD (LLC) ─────────────────────────
# Gerar em: Mercury Dashboard → Settings → API Tokens → Read-Only
# Docs: https://docs.mercury.com/docs/getting-started
MERCURY_API_KEY=""
# ID da conta checking principal (visível no Mercury Dashboard → Account → Settings)
MERCURY_ACCOUNT_ID=""
# secretKey gerado ao criar o webhook em: Mercury → Settings → Developer → Webhooks
# URL do webhook: https://seu-dominio.com/api/webhooks/mercury
# Eventos: transaction.created, transaction.updated
MERCURY_WEBHOOK_SECRET=""

