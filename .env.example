# Database — em produção (ex.: Hostinger MySQL) use uma única DATABASE_URL; não commite credenciais.
# Exemplo MySQL: DATABASE_URL="mysql://DB_USER:DB_PASS@DB_HOST:3306/DB_NAME?connection_limit=5"
# (DB_HOST, DB_USER, DB_PASS são só conveniência documental — o app lê só DATABASE_URL via Prisma.)
#
# Pré-voo Hostinger (checklist): DATABASE_URL · NEXTAUTH_URL (HTTPS) · NEXTAUTH_SECRET ·
# ECOSYSTEM_LEADS_INGEST_SECRET (webhook) · NODE_ENV=production · após build: prisma migrate deploy (ou SQL manual).
#
# PostgreSQL (dev): 
DATABASE_URL="postgresql://user:password@localhost:5432/erp_ads_ativos"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/erp_ads_ativos"

# NextAuth — em produção use URL HTTPS do app (Hostinger / domínio final)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Fallback para links em forgot-password / digest (se NEXTAUTH_URL estiver vazio em algum worker)
# NEXT_PUBLIC_APP_URL="https://app.seudominio.com"

# Setup: em produção, /setup é bloqueado. Use ALLOW_SETUP=1 apenas para emergência.
# ALLOW_SETUP="1"

# Criptografia (passwordPlain em repouso). Gere com: openssl rand -hex 32
ENCRYPTION_KEY=""

# Notificações - Digest diário e canais
CRON_SECRET="generate-with-openssl-rand-base64-32"
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE_ID="ads-ativos"
# Número para suporte (fallback: WHATSAPP_COMERCIAL)
WHATSAPP_SUPORTE=""
RESEND_API_KEY=""
EMAIL_FROM="notificacoes@seudominio.com"

# SMS - Aluguel de números para validação (5sim.net)
FIVESIM_API_KEY=""
FIVESIM_DEFAULT_COUNTRY="brazil"
FIVESIM_DEFAULT_OPERATOR=""

# Google Calendar - Onboarding (agenda)
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_CALENDAR_ID="primary"

# GTM - Google Tag Manager: fallback global do ERP (opcional). Cada cliente pode definir GTM-XXXXXXX em Meu Perfil (DB).
NEXT_PUBLIC_GTM_ID=""

# Integrações (opcional)
AIRTABLE_API_KEY=""
AIRTABLE_BASE_ID=""
# ─── Banco Inter — PIX Cobrança (OAuth2 + mTLS) ───────────────────────────────
# Credenciais obtidas no Portal Inter Empresas → API Banking
INTER_CLIENT_ID="503c4506-0838-4b6e-95a5-6aaa95493719"
INTER_CLIENT_SECRET="251f7799-be77-4b00-a2f0-3717274c17b6"
# Número da conta corrente (sem dígito verificador) — obrigatório na API v2
INTER_ACCOUNT_NUMBER=""
# Chave PIX cadastrada na conta (CNPJ, email ou chave aleatória)
INTER_PIX_KEY=""
# Segredo compartilhado para validar a autenticidade dos webhooks recebidos
INTER_PIX_WEBHOOK_SECRET=""
# Alternativa aos arquivos em /certs/ — cole o conteúdo PEM completo (com \n escapado)
INTER_CERT_CRT=""
INTER_CERT_KEY=""
# (Legado — manter para retrocompatibilidade)
BANCO_INTER_CLIENT_ID=""
BANCO_INTER_CLIENT_SECRET=""

# ADS CORE — ReceitaWS (integração real ao formulário gerente / POST criar ativo)
# GET https://receitaws.com.br/v1/cnpj/{14_digitos}  Header: Authorization: Bearer <token>
# Coloque o Bearer aqui (apenas no .env local / secrets do deploy — nunca no Git).
RECEITAWS_API_TOKEN=""
# Alternativa ao nome acima:
# RECEITA_WS_BEARER_TOKEN=""
# Base opcional se a API mudar de host/path (padrão: https://receitaws.com.br/v1/cnpj)
# RECEITAWS_API_BASE="https://receitaws.com.br/v1/cnpj"
# Em dev, exige token real (bloqueia mock): ADS_CORE_REQUIRE_REAL_CNPJ="true"

# ADS CORE — API CNPJ genérica (opcional, cai para CNPJ.ws / mock se vazio)
# RECEITA_CNPJ_API_URL="https://api.exemplo.com/cnpj"
# RECEITA_CNPJ_API_KEY=""

# CNPJ.ws comercial (opcional)
# CNPJ_WS_COMMERCIAL_TOKEN=""

# CNPJ.ws API pública (~3 req/min) — só se explicitamente habilitado
# ADS_CORE_CNPJ_WS_PUBLIC="true"

# Home pública (landing) — novidades, WhatsApp flutuante, teaser de estoque
# NEXT_PUBLIC_HOME_NEWS="Ex.: Novo módulo ADS CORE e relatório diário."
# NEXT_PUBLIC_WHATSAPP_SUPORTE="5511999990000"
# PUBLIC_STOCK_SNAPSHOT_ENABLED="true"

# Login — rate limit por IP (rota /api/auth/callback/credentials)
# LOGIN_RATE_LIMIT_WINDOW_SEC="900"
# LOGIN_RATE_LIMIT_MAX="12"

# Login — mensagens distintas para e-mail inexistente vs senha errada (facilita enumeração de contas; use só em ambiente controlado)
# LOGIN_VERBOSE_ERRORS="true"

# Sessão JWT — duração em segundos (com / sem “Manter conectado”)
# SESSION_SHORT_MAX_AGE_SEC="50400"
# SESSION_LONG_MAX_AGE_SEC="2592000"

# Produção Google G2 — alerta automático quando o motor de meta indica "Necessário/dia" acima do limite (máx. 1 envio/dia)
# G2_META_NECESSARIO_DIA_ALERT_THRESHOLD="30"
# G2_META_ALERT_SLACK_WEBHOOK="https://hooks.slack.com/services/..."
# G2_META_ALERT_WHATSAPP_PHONE="5511999990000"
# (WhatsApp usa WHATSAPP_API_URL / WHATSAPP_API_KEY já definidos acima)

# Cloudflare Turnstile (CAPTCHA invisível no login). Secret obrigatório se usar site key.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# ROI & CRM — TinTim + vendas ERP (/dashboard/roi-crm, /dashboard/comercial)
# Webhooks: POST /api/v1/webhooks/tintim (venda_aprovada / lead) ou POST /api/webhooks/tintim — sem secret o endpoint fica aberto (não recomendado em produção).
# TINTIM_WEBHOOK_SECRET="seu-token-secreto"
# Mapeamento product_id Tintim → nome do produto no pedido (JSON). Ex.: {"pacote_10":"Pacote 10 Contas"}
# TINTIM_PRODUCT_MAP_JSON=""
# User ID (Gustavo/Ramon) para responsável na fila Plug & Play quando o grupo de entrega é criado
# TINTIM_DELIVERY_RESPONSIBLE_USER_ID=""
# URL pública do app (links em e-mail/WhatsApp de boas-vindas)
# NEXT_PUBLIC_APP_URL="https://app.seudominio.com"
# Investimento diário: POST /api/roi-crm/daily-spend (ADMIN/FINANCE). Sync Google (placeholder): POST /api/roi-crm/sync-google-spend (ADMIN/FINANCE)

# Central de Inteligência de Leads — POST /api/v1/leads (WordPress/Elementor). Sem secret o endpoint recusa (401).
# UI: /dashboard/intelligence-leads (sessão ADMIN/COMMERCIAL/FINANCE). GET /api/v1/leads devolve contrato + dicas de segurança.
# Header: Authorization: Bearer <token> ou X-Leads-Token: <token>
# ECOSYSTEM_LEADS_INGEST_SECRET="gere-um-token-longo-aleatorio"
# Sincronizar LTV dos leads com pedidos ERP (mesmo e-mail de cliente): POST /api/admin/intelligence-leads/sync-orders (sessão ADMIN/FINANCE)
# Esteira de upsell — JSON: slug do produto comprado -> lista de slugs complementares (ex.: {"conta-meta":["proxy-dedicado"]})
# UPSELL_MATRIX_JSON="{}"
# Lead “quente parado” — eventos (exc. ORDER_PAID/NOTE) numa janela; padrão 5 em 24h
# INTELLIGENCE_HOT_STALLED_EVENT_THRESHOLD=5
# INTELLIGENCE_HOT_STALLED_WINDOW_HOURS=24
# Pulses multi-checkout — POST /api/v1/checkout/pulse (Bearer ou X-Checkout-Pulse-Token)
# ECOSYSTEM_CHECKOUT_PULSE_SECRET="token-longo"
# Alertas de gateway sem Approved / sem webhook (horas)
# CHECKOUT_PULSE_STALE_APPROVED_HOURS=48
# CHECKOUT_PULSE_STALE_WEBHOOK_HOURS=96
# Roteiro WhatsApp no painel (POST .../sales-script) — fallback local se vazio
# ANTHROPIC_API_KEY=""
# Resumo automático “Dica de venda” ao ingerir lead (POST /api/v1/leads): "true" para ligar
# LEAD_AI_BRIEF_AUTO="false"
# Modelo opcional (ex.: gpt-4o-mini, claude-3-5-sonnet-latest)
# LEAD_AI_BRIEF_MODEL=""
# Sessões de checkout + resgate: POST /api/v1/checkout/session (mesmo secret dos leads). Minutos em PAYMENT_PENDING antes de marcar lead em Resgate imediato
# CHECKOUT_RESCUE_AFTER_MINUTES="15"
# Saúde do tráfego (poll /api/admin/intelligence-leads/traffic-health): silêncio de webhooks, queda vs média; Telegram usa TELEGRAM_SALES_BOT_TOKEN + TELEGRAM_SALES_CHAT_ID se existirem
# TRAFFIC_ALERT_SILENCE_MINUTES="10"
# Janela (min) para média recente vs baseline — padrão 15 (queda de volume)
# TRAFFIC_ALERT_RECENT_WINDOW_MINUTES="15"
# TRAFFIC_ALERT_VOLUME_DROP_RATIO="0.25"
# TRAFFIC_ALERT_MIN_BASELINE_PER_MIN="2"
# TRAFFIC_ALERT_TELEGRAM_COOLDOWN_MS="2700000"
# Log de auditoria: GET /api/admin/commercial-audit-logs (ADMIN/FINANCE)

# Inventory Engine — copy IA (OPENAI_API_KEY já usado noutros módulos) e Telegram comunidade
# OPENAI_INVENTORY_COPY_MODEL="gpt-4o-mini"
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_COMMUNITY_CHAT_ID=""

# Provisioning Engine — domínios / landers em massa (Cloudflare + webhook servidor)
# CLOUDFLARE_API_TOKEN=""
# CLOUDFLARE_ACCOUNT_ID=""
# PROVISIONING_SERVER_WEBHOOK_URL=""
# PROVISIONING_WEBHOOK_SECRET=""

# Automation OS — Multilogin (API local no PC do cliente; valores por defeito abaixo)
# ADSPOWER_LOCAL_API_URL="http://127.0.0.1:50325"
# Alternativa comum: http://local.adspower.net:50325
# ADSPOWER_GROUP_ID="0"
# ADSPOWER_API_KEY=""
# Overrides JSON de fingerprint no create user (chaves AdsPower Local API), ex.: DNS / WebRTC
# ADSPOWER_FINGERPRINT_OVERRIDES_JSON='{"webrtc":"forward"}'
# Geo-Provision (Módulo 02): headless no start do browser; Playwright só se explicitamente ligado
# GEO_PROVISION_HEADLESS="1"
# GEO_PROVISION_IDENTITY_AUTOMATION="0"
# DOLPHIN_LOCAL_API_URL="http://127.0.0.1:3001"
# FFmpeg — limpeza de metadados em vídeos (rota /api/cliente/video-process)
# FFMPEG_PATH="ffmpeg"

# Ads Ativos Guard — Camada C (OCR em frames de VSL)
# GOOGLE_VISION_API_KEY=""
# Webhook opcional (também configurável em /dashboard/admin/guard)
# GUARD_NOTIFICATION_WEBHOOK="https://..."
# GUARD_WEBHOOK_SECRET=""

# Ads Ativos Tracker — Módulo 01: webhook opcional do seu edge (pausa rota / contingência / retomar)
# O ERP envia JSON com action: pause_route | delete_route | emergency_contingency | resume_route
# ADS_TRACKER_EDGE_WEBHOOK_URL="https://seu-servidor.example/hook"
# ADS_TRACKER_EDGE_WEBHOOK_SECRET=""
# Ping de saúde do edge/contingência (War Room mentorado) — POST /api/public/ads-tracker/contingency-ping com Bearer
# ADS_TRACKER_CONTINGENCY_PING_SECRET=""

# Módulo 02 — Armory (Central de Ativos): SLA de provisionamento (horas) e texto de meta RMA na UI
# ARMORY_SLA_HOURS="72"
# ARMORY_RMA_SLA_HOURS="48"
# Webhook blindagem de domínio (proxy reverso + Tracker) — POST JSON assinado HMAC-SHA256 (header X-Armory-Shield-Signature: sha256=...)
# ARMORY_DOMAIN_SHIELD_WEBHOOK_URL=""
# ARMORY_DOMAIN_SHIELD_SECRET=""
# Google Safe Browsing v4 (malware/phishing) — não substitui revisão manual nem “status Google Ads”
# GOOGLE_SAFE_BROWSING_API_KEY=""
# Módulo 13 — cron horário: GET /api/cron/tracker-domain-reputation (CRON_SECRET ou header x-vercel-cron em Vercel)
# Alertas Telegram (opcional; fallback TELEGRAM_BOT_TOKEN + TELEGRAM_COMMUNITY_CHAT_ID)
# TRACKER_ALERT_TELEGRAM_BOT_TOKEN=""
# TRACKER_ALERT_TELEGRAM_CHAT_ID=""
# Se "1", na primeira deteção WARNING por domínio aciona emergency_contingency nas campanhas ACTIVE desse host
# TRACKER_DOMAIN_REPUTATION_AUTO_PANIC="0"

# Pixel Hydra (postback /api/webhooks/affiliate): inclua gclid e, se possível, uni_id (UUID da vault_industrial_units) no JSON para ROI por UNI no Ads Tracker Módulo 02.

# Traffic Shield (Módulo 03) — ingestão de logs a partir do edge
