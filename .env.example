# TRAFFIC_SHIELD_EDGE_WEBHOOK_URL="https://seu-edge.example/hooks/traffic-shield"
# TRAFFIC_SHIELD_EDGE_SECRET=""

# URLs públicas para links de redirecionamento (Módulo 04 landings / tokens)
# NEXT_PUBLIC_APP_URL="https://app.seudominio.com"

