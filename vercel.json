{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "adsativos.com" }],
      "destination": "https://www.adsativos.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {"path": "/api/cron/daily-digest", "schedule": "0 8 * * *"},
    {"path": "/api/cron/relatorio-diario", "schedule": "0 20 * * *"},
    {"path": "/api/cron/tracker-domain-reputation", "schedule": "0 * * * *"},
    {"path": "/api/cron/health-monitor", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/cleanup-expired-pix", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/quick-sale-delivery-sla", "schedule": "*/10 * * * *"},
    {"path": "/api/cron/inter-token-warmup", "schedule": "*/30 * * * *"},
    {"path": "/api/cron/pix-recovery", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/repurchase-trigger", "schedule": "0 * * * *"},
    {"path": "/api/cron/warranty-alert", "schedule": "0 8,20 * * *"},
    {"path": "/api/cron/plano-ativo-renovar", "schedule": "0 9 * * *"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-War-Room-Version",
          "value": "war-room-os"
        }
      ]
    }
  ]
}
