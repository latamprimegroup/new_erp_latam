  @@map("account_spend_logs")
}

// Tickets de contestação e operações comerciais
enum ContestationType {
  BAN_CONTESTATION    // Conta banida - contestar
  REPLACEMENT_REQUEST // Solicitar reposição
  PAUSED_NEEDS_OPS    // Conta pausada - precisa operação comercial
}

enum ContestationStatus {
  OPEN
  IN_REVIEW
  REPLACEMENT_APPROVED
  RESOLVED
  REJECTED
}

model ContestationTicket {
  id                    String            @id @default(cuid())
  clientId              String            @map("client_id")
  client                ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  accountId             String            @map("account_id")
  account               StockAccount      @relation(fields: [accountId], references: [id])
  type                  ContestationType
  status                ContestationStatus @default(OPEN)
  priority              String            @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  slaResponseAt         DateTime?         @map("sla_response_at")  // Prazo primeira resposta
  slaResolveAt          DateTime?         @map("sla_resolve_at")   // Prazo resolução
  banReason             String?           @map("ban_reason") @db.Text
  description           String            @db.Text
  needsReplacement      Boolean           @default(false) @map("needs_replacement")
  commercialOpsRequested Boolean          @default(false) @map("commercial_ops_requested")
  accountReturned       Boolean?          @map("account_returned") // se a conta voltou
  resolutionNotes       String?           @map("resolution_notes") @db.Text
  resolvedAt            DateTime?         @map("resolved_at")
  resolvedById          String?           @map("resolved_by_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([status, priority])
  @@map("contestation_tickets")
}

// Ticket de suporte - área do cliente
model SupportTicket {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject     String
  description String   @db.Text
  category    String   @default("GERAL")  // GERAL, DUVIDA, PROBLEMA, SOLICITACAO
  status      String   @default("OPEN")   // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  ticketNumber String  @unique @map("ticket_number")  // TKT-0001
  whatsappSentAt DateTime? @map("whatsapp_sent_at")
  resolvedAt  DateTime? @map("resolved_at")
  resolvedNote String? @map("resolved_note") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  serviceOrder ServiceOrder?

  @@index([clientId])
  @@index([status])
  @@index([ticketNumber])
  @@map("support_tickets")
}

// Ordem de serviço - vinculada a ticket ou criada diretamente
model ServiceOrder {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ticketId     String?  @unique @map("ticket_id")
  ticket       SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  type         String   @default("MANUTENCAO")  // MANUTENCAO, CONFIGURACAO, TREINAMENTO, SUPORTE, OUTRO
  title        String
  description  String   @db.Text
  status       String   @default("ABERTA")  // ABERTA, EM_ANDAMENTO, AGUARDANDO_CLIENTE, CONCLUIDA, CANCELADA
  orderNumber  String   @unique @map("order_number")  // OS-0001
  scheduledAt  DateTime? @map("scheduled_at")
  completedAt  DateTime? @map("completed_at")
  whatsappSentAt DateTime? @map("whatsapp_sent_at")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@index([orderNumber])
  @@map("service_orders")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  accounts    StockAccount[]
  emailBatches EmailBatch[]
  emails     Email[]
}

// ============ BASE EMAILS / CNPJs / PERFIS (Estoque com Atribuição Exclusiva) ============

model EmailBatch {
  id              String   @id @default(cuid())
  supplierId      String   @map("supplier_id")
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  uploadedById    String   @map("uploaded_by_id")
  uploadedBy      User     @relation("EmailBatchUploader", fields: [uploadedById], references: [id])
  filename        String
  totalImported   Int      @map("total_imported")
  failedCount     Int      @default(0) @map("failed_count")
  duplicateCount  Int      @default(0) @map("duplicate_count")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  emails          Email[]
}

model Email {
  id                  String          @id @default(cuid())
  email               String          @unique  // Unicidade global - nunca duplicar
  recovery            String?
  passwordHash        String?         @map("password_hash")
  passwordPlain       String?         @map("password_plain") @db.Text  // Criptografado em repouso; usado na produção
  status              StockItemStatus @default(AVAILABLE)
  countryId           String?         @map("country_id")
  country             Country?        @relation(fields: [countryId], references: [id])
  supplierId          String?         @map("supplier_id")
  supplier            Supplier?       @relation(fields: [supplierId], references: [id])
  batchId             String?         @map("batch_id")
  batch               EmailBatch?     @relation(fields: [batchId], references: [id])
  accountId           String?         @map("account_id")  // Conta de estoque vinculada (quando em uso)
  account             StockAccount?   @relation(fields: [accountId], references: [id])
  assignedToProducerId String?        @map("assigned_to_producer_id")
  assignedToProducer  User?           @relation("AssignedEmails", fields: [assignedToProducerId], references: [id])
  assignedAt          DateTime?       @map("assigned_at")
  consumedAt          DateTime?       @map("consumed_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  productionAccount   ProductionAccount?
  productionG2        ProductionG2?

  @@index([status, countryId])
  @@index([assignedToProducerId])
}

model Cnpj {
  id                  String          @id @default(cuid())
  cnpj                String          @unique  // Unicidade global
  razaoSocial         String?         @map("razao_social")
  nomeFantasia        String?         @map("nome_fantasia")
  cnae                String?         // Código CNAE principal
  cnaeDescricao       String?         @map("cnae_descricao") @db.Text
  cnaesSecundarios    Json?           @map("cnaes_secundarios") // Array de códigos/descrições
  status              StockItemStatus @default(AVAILABLE)
  countryId           String?         @map("country_id")
  country             Country?        @relation(fields: [countryId], references: [id])
  nicheId             String?         @map("niche_id")
  niche               Niche?          @relation(fields: [nicheId], references: [id])
  accountId           String?         @map("account_id")
  account             StockAccount?   @relation(fields: [accountId], references: [id])
  assignedToProducerId String?        @map("assigned_to_producer_id")
  assignedToProducer  User?           @relation("AssignedCnpjs", fields: [assignedToProducerId], references: [id])
  assignedAt          DateTime?       @map("assigned_at")
  consumedAt          DateTime?       @map("consumed_at")
  sourceApi           String?         @map("source_api")  // Brasil API, ReceitaWS, etc.
  fetchedAt           DateTime?       @map("fetched_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  paymentProfiles     PaymentProfile[]
  productionAccount   ProductionAccount?
  productionG2        ProductionG2?

  @@index([status, countryId])
  @@index([assignedToProducerId])
}

model PaymentProfile {
  id                  String          @id @default(cuid())
  type                String
  gateway             String
  status              StockItemStatus @default(AVAILABLE)
  cnpjId              String?         @map("cnpj_id")
  cnpj                Cnpj?           @relation(fields: [cnpjId], references: [id])
  accountId           String?         @map("account_id")
  account             StockAccount?   @relation(fields: [accountId], references: [id])
  countryId           String?         @map("country_id")
  country             Country?        @relation(fields: [countryId], references: [id])
  assignedToProducerId String?        @map("assigned_to_producer_id")
  assignedToProducer  User?           @relation("AssignedPaymentProfiles", fields: [assignedToProducerId], references: [id])
  assignedAt          DateTime?       @map("assigned_at")
  consumedAt          DateTime?       @map("consumed_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  productionAccount   ProductionAccount?
  productionG2        ProductionG2?

  @@index([status, countryId])
  @@index([assignedToProducerId])
}

// ============ VENDAS E PEDIDOS ============

enum OrderStatus {
  QUOTE
  AWAITING_PAYMENT
  PENDING
  APPROVED
  REJECTED
  PAID
  IN_SEPARATION
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  clientId    String      @map("client_id")
  client      ClientProfile @relation(fields: [clientId], references: [id])
  country     String?
  product     String
  accountType String      @map("account_type")
  quantity    Int         @default(1)
  value       Decimal     @db.Decimal(12, 2)
  currency    String      @default("BRL")  // ISO 4217 para multi-moeda
  status      OrderStatus @default(AWAITING_PAYMENT)
  sellerId    String?     @map("seller_id")
  seller      User?       @relation("OrderSeller", fields: [sellerId], references: [id])
  pixKey      String?     @map("pix_key")
  pixQrCode   String?     @map("pix_qr_code") @db.Text
  paymentDueAt DateTime? @map("payment_due_at")
  paidAt      DateTime?  @map("paid_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  items       OrderItem[]
  delivery    Delivery?
  deliveryGroups DeliveryGroup[]
  financialEntries FinancialEntry[]

  @@index([clientId, status])
  @@index([paidAt])
  @@index([status, paidAt])
  @@index([createdAt])
}

model OrderItem {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id])
  accountId String      @map("account_id")
  account   StockAccount @relation(fields: [accountId], references: [id])
  quantity  Int         @default(1)
}

// ============ ENTREGAS ============

enum DeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  DELAYED
}

model Delivery {
  id             String        @id @default(cuid())
  orderId        String        @unique @map("order_id")
  order          Order         @relation(fields: [orderId], references: [id])
  qtySold        Int           @map("qty_sold")
  qtyDelivered   Int           @default(0) @map("qty_delivered")
  accountsDelivered String?    @map("accounts_delivered") @db.Text
  status         DeliveryStatus @default(PENDING)
  sla            DateTime?
  responsibleId  String?       @map("responsible_id")
  responsible    User?         @relation(fields: [responsibleId], references: [id])
  deliveredAt    DateTime?     @map("delivered_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
}

// ============ MÓDULO DE ENTREGAS (ADS ATIVOS) ============

enum DeliveryGroupStatus {
  AGUARDANDO_INICIO
  EM_ANDAMENTO
  PARCIALMENTE_ENTREGUE
  FINALIZADA
  ATRASADA
  EM_REPOSICAO
  CANCELADA
}

enum DeliveryAccountType {
  USD
  BRL
}

enum DeliveryPaymentType {
  AUTOMATICO
  MANUAL
}

model DeliveryGroup {
  id                    String              @id @default(cuid())
  groupNumber           String              @unique @map("group_number")  // GR-0001
  lastUpdatedAt         DateTime?           @map("last_updated_at") // Última atualização operacional (gerado automaticamente)
  clientId              String              @map("client_id")
  client                ClientProfile       @relation(fields: [clientId], references: [id])
  orderId               String?             @map("order_id")
  order                 Order?              @relation(fields: [orderId], references: [id])
  whatsappGroupLink     String              @unique @map("whatsapp_group_link")
  accountType           DeliveryAccountType @map("account_type")
  quantityContracted    Int                 @map("quantity_contracted")
  quantityDelivered     Int                 @default(0) @map("quantity_delivered")
  currency              String              @default("BRL")
  paymentType           DeliveryPaymentType @map("payment_type")
  estimatedTimeHours    Int?                @map("estimated_time_hours")
  expectedCompletionAt  DateTime?           @map("expected_completion_at")
  status                DeliveryGroupStatus @default(AGUARDANDO_INICIO)
  completedAt           DateTime?           @map("completed_at")
  responsibleId         String              @map("responsible_id")
  responsible           User                @relation(fields: [responsibleId], references: [id])
  groupCreatedAt        DateTime            @default(now()) @map("group_created_at")
  saleDate              DateTime?           @map("sale_date")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  repositions           DeliveryReposition[]
  returns               DeliveryReturn[]
  financialEntries      FinancialEntry[]
  logs                  DeliveryGroupLog[]
  productionG2Items    ProductionG2[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("delivery_groups")
}

enum RepositionReason {
  BLOQUEIO
  LIMITE_GASTO
  ERRO_ESTRUTURAL
  PROBLEMA_PERFIL
  OUTRO
}

enum RepositionStatus {
  SOLICITADA
  APROVADA
  NEGADA
  CONCLUIDA
}

model DeliveryReposition {
  id            String          @id @default(cuid())
  deliveryId    String          @map("delivery_id")
  delivery      DeliveryGroup   @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  quantity      Int
  reason        RepositionReason
  reasonOther   String?         @map("reason_other") @db.Text
  status        RepositionStatus @default(SOLICITADA)
  requestedAt   DateTime        @default(now()) @map("requested_at")
  analystId     String?         @map("analyst_id")
  analyst       User?           @relation(fields: [analystId], references: [id])
  resolvedAt    DateTime?       @map("resolved_at")
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([deliveryId])
  @@index([status])
  @@map("delivery_repositions")
}

// Devolução de contas (impacto financeiro, crédito, ajuste LTV)
model DeliveryReturn {
  id            String   @id @default(cuid())
  deliveryId    String   @map("delivery_id")
  delivery      DeliveryGroup @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  quantity      Int      // Quantidade devolvida
  reason        String?  @db.Text
  status        String   @default("REGISTRADA") // REGISTRADA, CREDITO_APLICADO
  valueAdjusted Decimal? @map("value_adjusted") @db.Decimal(12, 2) // Valor do crédito/ajuste
  createdAt     DateTime @default(now()) @map("created_at")
  createdById   String?  @map("created_by_id")

  @@index([deliveryId])
  @@map("delivery_returns")
}

model DeliveryGroupLog {
  id          String   @id @default(cuid())
  deliveryId  String   @map("delivery_id")
  delivery    DeliveryGroup @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?  @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([deliveryId])
  @@index([createdAt])
  @@map("delivery_group_logs")
}

// ============ FINANCEIRO ============

enum FinancialType {
  INCOME
  EXPENSE
}

model FinancialCategory {
  id       String   @id @default(cuid())
  name     String
  type     FinancialType
  active   Boolean  @default(true)
  entries  FinancialEntry[]
}

model FinancialEntry {
  id             String       @id @default(cuid())
  type           FinancialType
  category       String
  categoryId     String?      @map("category_id")
  financialCategory FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter     String?      @map("cost_center")
  value          Decimal      @db.Decimal(12, 2)
  currency       String       @default("BRL")
  date           DateTime
  orderId        String?      @map("order_id")
  order          Order?       @relation(fields: [orderId], references: [id])
  deliveryGroupId String?     @map("delivery_group_id")
  deliveryGroup  DeliveryGroup? @relation(fields: [deliveryGroupId], references: [id])
  netProfit      Decimal?     @map("net_profit") @db.Decimal(12, 2)
  description    String?      @db.Text
  reconciled     Boolean      @default(false) @map("reconciled")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([date])
  @@index([orderId])
  @@index([deliveryGroupId])
}

// ============ SAQUES ============

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  HELD
  FAILED
}

model Withdrawal {
  id          String          @id @default(cuid())
  userId      String?         @map("user_id") // Produtor que solicitou (saque por meta)
  user        User?           @relation(fields: [userId], references: [id])
  gateway     String
  accountId   String?         @map("account_id")
  value       Decimal         @db.Decimal(12, 2)
  fee         Decimal?        @db.Decimal(12, 2)
  netValue    Decimal         @map("net_value") @db.Decimal(12, 2)
  status      WithdrawalStatus @default(PENDING)
  dueDate     DateTime?       @map("due_date")
  risk        String?
  holdReason  String?         @map("hold_reason") @db.Text
  reconciled  Boolean         @default(false) @map("reconciled")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============ METAS E BÔNUS ============

model Goal {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  dailyTarget     Int      @map("daily_target")
  monthlyTarget   Int      @map("monthly_target")
  productionCurrent Int    @default(0) @map("production_current")
  bonus           Decimal? @db.Decimal(12, 2)
  status          String   @default("active")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bonusReleases   BonusRelease[]

  @@index([userId, periodStart])
  @@index([status])
}

model BonusRelease {
  id        String   @id @default(cuid())
  goalId    String   @map("goal_id")
  goal      Goal     @relation(fields: [goalId], references: [id])
  value     Decimal  @db.Decimal(12, 2)
  status    String   @default("pending")
  releasedAt DateTime? @map("released_at")
  createdAt DateTime @default(now()) @map("created_at")
}

// Fechamento mensal do produtor: salário + valor por conta + bônus. Ao fechar, libera saque.
model ProducerMonthlyStatement {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  month            Int
  year             Int
  accountsApproved Int      @map("accounts_approved")
  baseSalary       Decimal  @map("base_salary") @db.Decimal(12, 2)
  perAccountTotal  Decimal  @map("per_account_total") @db.Decimal(12, 2)
  bonusTotal       Decimal  @map("bonus_total") @db.Decimal(12, 2)
  totalAmount      Decimal  @map("total_amount") @db.Decimal(12, 2)
  status           String   @default("PENDING") // PENDING, CLOSED (libera saque)
  closedAt         DateTime? @map("closed_at")
  closedById       String?   @map("closed_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([userId, month, year])
  @@map("producer_monthly_statements")
}

// ============ COTAÇÕES ============

model Quotation {
  id         String       @id @default(cuid())
  clientId   String       @map("client_id")
  client     ClientProfile @relation(fields: [clientId], references: [id])
  accountId  String       @map("account_id")
  account    StockAccount @relation(fields: [accountId], references: [id])
  status     String       @default("pending")
  message    String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")
}

// ============ CONFIGURAÇÃO GLOBAL ============

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
}

// ============ CONTINGÊNCIA BLACK - PLUG & PLAY ============

enum BlackOperationStatus {
  DRAFT
  EM_AQUECIMENTO
  EM_CONFIG
  LIVE
  SURVIVED_24H
  BANNED
}

enum BlackStepType {
  AQUECIMENTO_G2
  DOMINIO_NICHO
  AQUECIMENTO_CONTA
  CLOAKER
  PAGINA_WHITE
  PAGINA_BLACK
  YOUTUBE_CANAL
  CRIATIVO_BLACK
}

model BlackOperation {
  id              String              @id @default(cuid())
  collaboratorId  String              @map("collaborator_id")
  collaborator    User                @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  niche           String
  domain          String?
  stockAccountId  String?             @map("stock_account_id")
  status          BlackOperationStatus @default(DRAFT)
  wentLiveAt      DateTime?           @map("went_live_at")
  bannedAt        DateTime?           @map("banned_at")
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  steps     BlackOperationStep[]
  payment   BlackPayment?
}

model BlackOperationStep {
  id          String       @id @default(cuid())
  operationId String       @map("operation_id")
  operation   BlackOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  stepType    BlackStepType @map("step_type")
  status      String       @default("PENDING") // PENDING, IN_PROGRESS, DONE
