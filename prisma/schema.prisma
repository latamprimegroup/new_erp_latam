// ============ ADS CORE (ativos CNPJ / documentos — escala, footprint, isolamento 1:1) ============

enum AdsCoreAssetProductionStatus {
  DISPONIVEL
  EM_PRODUCAO
  VERIFICACAO_G2
  APROVADO
  REPROVADO
}

/// Meta operacional da demanda (visível ao produtor e ao gerente)
enum AdsCoreVerificationTrack {
  G2_ANUNCIANTE
  ANUNCIANTE_COMERCIAL
}

enum AdsCoreRgStockStatus {
  DISPONIVEL
  EM_USO
  UTILIZADO
}

/// Nichos com briefing (Nutracêuticos, iGaming, etc.)
model AdsCoreNiche {
  id                     String                   @id @default(cuid())
  name                   String                   @db.VarChar(120)
  briefingInstructions   String?                  @map("briefing_instructions") @db.Text
  /// Palavras-chave para congruência textual (CNAE / atividade) quando o código não bate sozinho
  congruenceKeywords     Json?                    @map("congruence_keywords")
  active                 Boolean                  @default(true)
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  assets                 AdsCoreAsset[]
  allowedCnaes           AdsCoreNicheAllowedCnae[]
  producerAssignments    AdsCoreProducerNiche[]

  @@map("ads_core_niches")
}

/// Produtores habilitados por nicho (atribuição filtrada). Sem linhas para um nicho = qualquer produtor.
model AdsCoreProducerNiche {
  id         String       @id @default(cuid())
  nicheId    String       @map("niche_id")
  niche      AdsCoreNiche @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  producerId String       @map("producer_id")
  producer   User         @relation("AdsCoreProducerNicheProducer", fields: [producerId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now()) @map("created_at")

  @@unique([nicheId, producerId])
  @@index([producerId])
  @@map("ads_core_producer_niches")
}

model AdsCoreNicheAllowedCnae {
  id      String       @id @default(cuid())
  nicheId String       @map("nicho_id")
  niche   AdsCoreNiche @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  code    String       @db.VarChar(20)

  @@unique([nicheId, code])
  @@index([nicheId])
  @@map("ads_core_niche_allowed_cnaes")
}

/// Ativo cadastral — CNPJ e site únicos (footprint); produtor só vê o que lhe foi atribuído
model AdsCoreAsset {
  id        String       @id @default(cuid())
  nicheId   String       @map("niche_id")
  niche     AdsCoreNiche @relation(fields: [nicheId], references: [id], onDelete: Restrict)
  producerId String?     @map("producer_id")
  producer   User?      @relation("AdsCoreAssetProducer", fields: [producerId], references: [id], onDelete: SetNull)
  /// Gerente que supervisiona / atribui (opcional)
  adminId    String?    @map("admin_id")
  admin      User?      @relation("AdsCoreAssetAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  createdById String    @map("created_by_id")
  createdBy   User       @relation("AdsCoreAssetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  cnpj              String   @unique @db.VarChar(14)
  razaoSocial       String?  @map("razao_social") @db.VarChar(300)
  nomeFantasia      String?  @map("nome_fantasia") @db.VarChar(300)
  dataAbertura      DateTime? @map("data_abertura")
  situacaoCadastral String?  @map("situacao_cadastral") @db.VarChar(80)

  endereco String? @db.Text
  logradouro String? @db.VarChar(200)
  numero     String? @db.VarChar(20)
  bairro     String? @db.VarChar(120)
  cidade     String? @db.VarChar(120)
  estado     String? @db.VarChar(2)
  cep        String? @db.VarChar(12)

  nomeSocio           String?   @map("nome_socio") @db.VarChar(200)
  cpfSocio            String?   @map("cpf_socio") @db.VarChar(14)
  dataNascimentoSocio DateTime? @map("data_nascimento_socio")

  emailEmpresa   String? @map("email_empresa") @db.VarChar(255)
  telefone       String? @db.VarChar(40)
  cnae           String? @db.VarChar(20)
  cnaeDescricao  String? @map("cnae_descricao") @db.Text
  statusReceita  String  @map("status_receita") @db.VarChar(120)
  siteUrl        String? @unique @map("site_url") @db.VarChar(500)

  congruenciaCheck Boolean @default(false) @map("congruencia_check")
  historicoUrls    Json?   @map("historico_urls")
  /// Checklist gerente: legivel | rejeitado por tipo de documento (cnpj, rg-frente, rg-verso)
  docReviewFlags   Json?   @map("doc_review_flags")
  /// Notas do produtor ao finalizar verificação G2 (Bloco 4)
  g2ProducerObservacoes String? @map("g2_producer_observacoes") @db.Text
  /// Momento em que o produtor foi atribuído (SLA: até G2)
  producerAssignedAt DateTime? @map("producer_assigned_at")
  /// Momento em que o produtor enviou para verificação G2
  g2FinalizedAt DateTime? @map("g2_finalized_at")
  /// Motivo obrigatório quando status = REPROVADO (arquivo morto / contestação)
  rejectionReason String? @map("rejection_reason") @db.Text
  /// Admin reabre edição de URL / linha para o produtor (pós-aprovado ou exceção)
  producerSiteEditUnlocked Boolean @default(false) @map("producer_site_edit_unlocked")

  statusProducao AdsCoreAssetProductionStatus @map("status_producao")
  /// G2 + Anunciante vs Anunciante + Operações Comerciais (especificação ADS CORE)
  verificationTrack AdsCoreVerificationTrack @default(G2_ANUNCIANTE) @map("verification_track")

  docCnpjPath      String? @map("doc_cnpj_path") @db.VarChar(500)
  docRgFrentePath  String? @map("doc_rg_frente_path") @db.VarChar(500)
  docRgVersoPath   String? @map("doc_rg_verso_path") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rgStockRows AdsCoreRgStock[]

  @@index([nicheId])
  @@index([producerId])
  @@index([adminId])
  @@index([statusProducao, createdAt])
  @@index([createdAt])
  @@map("ads_core_assets")
}

/// Bloqueio de reutilização de CNPJ após processamento (mesmo com exclusão do ativo)
model AdsCoreCnpjRegistry {
  cnpj         String   @id @db.VarChar(14)
  producerId   String?  @map("producer_id")
  producerName String?  @map("producer_name") @db.VarChar(200)
  processedAt  DateTime @map("processed_at")
  /// ATIVO | DELETE | REPROVADO — contexto do bloqueio
  source       String   @default("ATIVO") @map("source") @db.VarChar(24)
  blockReason  String?  @map("block_reason") @db.VarChar(500)

