// ERP Ads Ativos - Modelagem de Dados
// Baseado no wireframe completo + Multi-país, Receita Federal, Atribuição exclusiva

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ MULTI-TENANCY ============

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique  // ex: ads-ativos, latam-prime
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

// ============ USUÁRIOS E AUTENTICAÇÃO ============

enum Role {
  ADMIN
  PRODUCER
  DELIVERER
  FINANCE
  COMMERCIAL
  CLIENT
  MANAGER
  PRODUCTION_MANAGER  // Gerente de Produção: conferência diária, valida com senha
  PLUG_PLAY  // Operador Contingência Black - Plug & Play
  PURCHASING  // Setor de Compras — vê dados de fornecedor (Double-Blind)
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  name          String?
  phone         String?
  photo         String?
  /// Preferência de idioma (UI): pt-BR | en-US | es — i18n área cliente
  languageCode  String    @default("pt-BR") @map("language_code") @db.VarChar(12)
  role          Role      @default(CLIENT)
  emailVerified DateTime? @map("email_verified")
  /// Último login (credenciais) — follow-up comercial pós-compra Tintim
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  producerProfile  ProducerProfile?
  delivererProfile DelivererProfile?
  clientProfile    ClientProfile?
  managerProfile   ManagerProfile?

  productionAccounts ProductionAccount[]
  ordersSold         Order[]           @relation("OrderSeller")
  deliveries         Delivery[]
  goals              Goal[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  withdrawals        Withdrawal[]
  monthlyStatements  ProducerMonthlyStatement[]

  // Dados atribuídos exclusivamente a este produtor
  assignedEmails        Email[]         @relation("AssignedEmails")
  assignedCnpjs         Cnpj[]          @relation("AssignedCnpjs")
  assignedPaymentProfiles PaymentProfile[] @relation("AssignedPaymentProfiles")
  emailBatchesUploaded  EmailBatch[]    @relation("EmailBatchUploader")
  blackOperations           BlackOperation[]
  blackPayments             BlackPayment[]
  plugPlayMonthlyStatements PlugPlayMonthlyStatement[]

  deliveryGroupsAsResponsible DeliveryGroup[]
  deliveryRepositionsAsAnalyst DeliveryReposition[]
  deliveryGroupLogs          DeliveryGroupLog[]

  notificationPreference NotificationPreference?
  pushSubscriptions     PushSubscription[]
  productionG2Created     ProductionG2[]       @relation("ProductionG2Creator")
  productionG2CredentialViews ProductionG2CredentialViewLog[]

  productionAccountsValidated ProductionAccount[] @relation("ProductionAccountValidatedBy")
  productionG2Validated       ProductionG2[]      @relation("ProductionG2ValidatedBy")
  accountArchiveBatches      AccountArchiveBatch[]
  productionAlerts           ProductionAlert[]
  g2ManagerFeedbackReceived  G2ManagerFeedback[] @relation("G2FeedbackTarget")
  g2ManagerFeedbackAuthored  G2ManagerFeedback[] @relation("G2FeedbackAuthor")
  documentAssetsUploaded     DocumentAsset[]
  onboardingMeetingsCreated  OnboardingMeeting[] @relation("OnboardingMeetingCreator")
  onboardingParticipations   OnboardingParticipant[]
  sellerCommercialScores     SellerCommercialScore[]
  operatorScores             OperatorScore[]
  suggestions                Suggestion[]
  commercialLeadsAssigned    CommercialLead[] @relation("CommercialLeadAssignee")
  intelligenceLeadsAssigned  IntelligenceLead[] @relation("IntelligenceLeadAssignee")
  commercialContactLogs    CommercialContactLog[]
  chargebacksAuthored      ChargebackRecord[]       @relation("ChargebackCreatedBy")
  producerVaultCycles      ProducerVaultCycle[]
  adsRefundRequests        AdsRefundRequest[]
  domainProvisionBatches   DomainProvisionBatch[]
  rmaMessages              RmaMessage[]
  rmaAssigned              AccountReplacementRequest[] @relation("RmaAssignedTo")
  clientsAsAccountManager  ClientProfile[] @relation("ClientAccountManager")
  clientTechnicalNotesAuthored ClientTechnicalNote[]

  adsCoreAssetsCreated     AdsCoreAsset[] @relation("AdsCoreAssetCreatedBy")
  adsCoreAssetsAsProducer  AdsCoreAsset[] @relation("AdsCoreAssetProducer")
  adsCoreAssetsAsAdmin     AdsCoreAsset[] @relation("AdsCoreAssetAdmin")
  /// Nichos ADS CORE em que o produtor pode receber atribuições (vazio no nicho = todos os produtores)
  adsCoreProducerNiches    AdsCoreProducerNiche[] @relation("AdsCoreProducerNicheProducer")
  trafficShieldIpBlocks    TrafficShieldIpBlock[]
  warRoomLiveMessages      WarRoomLiveMessage[]
  commercialDataAuditLogs  CommercialDataAuditLog[]

  inventoryChecks          InventoryCheck[]
  stockMovements           StockMovement[]
  /// Taxa de comissão do vendedor em % (ex: 5.00 = 5%). Usado no bridge comercial→financeiro.
  commissionRate           Decimal? @map("commission_rate") @db.Decimal(5, 2)

  // Supply Chain / Compras
  assetMovements           AssetMovement[]
  purchaseOrdersCreated    PurchaseOrder[] @relation("PurchaseOrderCreator")

  @@index([phone])
}

model ProducerProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Chave PIX para pagamento de saques (cadastro pelo produtor)
  pixKey String? @map("pix_key") @db.VarChar(120)
}

model DelivererProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id                    String                @id @default(cuid())
  userId                String                @unique @map("user_id")
  clientCode            String?               @unique @map("client_code")  // Ex: C273
  country               String?
  whatsapp              String?
  notifyEmail           Boolean               @default(true) @map("notify_email")
  notifyWhatsapp        Boolean               @default(true) @map("notify_whatsapp")
  /// Google Tag Manager (container por cliente — atribuição / conversões)
  gtmId                 String?               @map("gtm_id") @db.VarChar(32)
  /// Texto do nicho para mensagem do widget WhatsApp / Join.Chat (sites e ERP)
  widgetNiche           String?               @map("widget_niche") @db.VarChar(200)
  lastPurchaseAt        DateTime?             @map("last_purchase_at")
  totalSpent            Decimal?              @map("total_spent") @db.Decimal(12, 2)
  totalAccountsBought   Int                   @default(0) @map("total_accounts_bought")
  // Perfil de Reputação (melhoria 004)
  reputationScore       Int?                  @map("reputation_score")   // 0-100
  averageAccountLifetimeDays Float?           @map("average_account_lifetime_days") @db.Float
  refundCount           Int                   @default(0) @map("refund_count")
  nicheTag              ClientNicheTag?       @map("niche_tag")
  plugPlayErrorCount    Int                   @default(0) @map("plug_play_error_count")  // Garantia reversa: 3 erros = blacklist
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders                Order[]
  quotations            Quotation[]
  accountsDelivered     StockAccount[]        @relation("ClientAccounts")
  deliveryGroups        DeliveryGroup[]
  contestationTickets   ContestationTicket[]
  supportTickets        SupportTicket[]
  serviceOrders         ServiceOrder[]
  accountSolicitations  AccountSolicitation[]
  productionG2Items     ProductionG2[]        @relation("ProductionG2Client")
  onboardingMeetings    OnboardingMeeting[]
  metrics               CustomerMetrics?
  landingBriefings     LandingBriefing[]
  landingPages         LandingPage[]
  landingDomains       LandingDomain[]
  leadsFromFunnel      CommercialLead[] @relation("LeadToClient")
  tintimLeadEvents     TintimLeadEvent[]

  /// CRM ROI — status comercial para remarketing
  roiCrmStatus           String    @default("ATIVO") @map("roi_crm_status") @db.VarChar(20)
  /// Última campanha atribuída (ex.: TinTim / UTM)
  roiAttributionCampaign String?   @map("roi_attribution_campaign") @db.VarChar(300)
  roiLastAttributionAt   DateTime? @map("roi_last_attribution_at")
  /// Notas internas do comercial (preferências, follow-up)
  commercialNotes       String?   @map("commercial_notes") @db.Text
  lastContactDate       DateTime? @map("last_contact_date")
  commercialContactLogs CommercialContactLog[]
  walletLedger          ClientWalletLedger[]
  domainProvisionBatches DomainProvisionBatch[]
  accountReplacementRequests AccountReplacementRequest[]
  /// Scripts UTMify/Redtrack replicados em landers (ecossistema)
  globalTrackingScript  String?  @map("global_tracking_script") @db.Text
  /// Rodapé sugerido (CNPJ/políticas) — compliance
  complianceFooterDefault String? @map("compliance_footer_default") @db.Text
  /// Origem atribuída (Meta / Google / orgânico) — webhook Tintim & UTM
  leadAcquisitionSource   String?  @map("lead_acquisition_source") @db.VarChar(24)
  /// True até o cliente fazer primeiro login após compra Tintim (alerta comercial 24h)
  tintimFollowupPending   Boolean  @default(false) @map("tintim_followup_pending")
  /// CNPJ / Tax ID / EIN (Brasil ou internacional)
  taxId                   String?  @map("tax_id") @db.VarChar(32)
  companyName             String?  @map("company_name") @db.VarChar(200)
  jobTitle                String?  @map("job_title") @db.VarChar(120)
  telegramUsername        String?  @map("telegram_username") @db.VarChar(64)
  timezone                String?  @map("timezone") @db.VarChar(64)
  /// E-mail AdsPower / chave de transferência de perfis
  adsPowerEmail           String?  @map("adspower_email") @db.VarChar(150)
  /// Nicho principal de operação (Black, Health, iGaming, White, etc.)
  operationNiche          String?  @map("operation_niche") @db.VarChar(48)
  /// 1–5 — experiência / confiança operacional (interno + comercial)
  trustLevelStars         Int?     @map("trust_level_stars")
  preferredCurrency       String   @default("BRL") @map("preferred_currency") @db.VarChar(8)
  preferredPaymentMethod  String?  @map("preferred_payment_method") @db.VarChar(32)
  accountManagerId        String?  @map("account_manager_id")
  accountManager          User?    @relation("ClientAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  /// Histórico técnico suporte (proxies, BMs, padrões) — visível só admin/comercial
  technicalSupportNotes   String?  @map("technical_support_notes") @db.Text
  clientStatus            String   @default("ATIVO") @map("client_status") @db.VarChar(20)
  technicalNoteEntries    ClientTechnicalNote[]
  /// Ads Ativos — UNIs expostas na War Room do mentorado (atribuídas por admin/comercial).
  mentoradoUniAccesses    ClientMentoradoUniAccess[]
  /// Módulo 03 — Creative Vault & agência on-demand
  creativeAgencyJobs         CreativeAgencyJob[]
  creativeAdMetricsEntries   CreativeAdMetricsEntry[]
  clienteVslWatches          ClienteVslWatch[]
  vslAdjustmentRequests      VslAdjustmentRequest[]
  /// Módulo 04 — Shield & Tracker (links blindados / pay + postback)
  mentoradoShieldTrackerLinks MentoradoShieldTrackerLink[]
  /// Módulo 05 — pré-flight de campanha (War Room Live)
  campaignPreflightReviews    CampaignPreflightReview[]
  /// Módulo 07 — Live Proof Labs (réplicas de ofertas validadas)
  liveProofLabReplicates      LiveProofLabReplicateLog[]
  liveProofTemplateUnlocks    LiveProofLabTemplateUnlock[]
  /// Welcome Experience — modal de onboarding até "Finalizar setup" (equivalente a first_login)
  welcomeOnboardingPending    Boolean  @default(true) @map("welcome_onboarding_pending")
  /// Gamificação — patente e lucro em cache (atualizados na API summary)
  gamificationRankCached             String?   @map("gamification_rank_cached") @db.VarChar(32)
  gamificationTotalNetProfitBrl      Decimal?  @map("gamification_total_net_profit_brl") @db.Decimal(14, 2)
  /// Última patente para a qual o mentorado já viu animação "level up" (evita repetir)
  gamificationLastCelebratedRank     String?   @map("gamification_last_celebrated_rank") @db.VarChar(32)
  gamificationRedemptions     ClientGamificationRedemption[]
  /// 0–100 — qualidade / risco (antifraude, histórico)
  trustScore            Int?     @map("trust_score")
  /// Ticket médio (pedidos pagos)
  averageTicketBrl      Decimal? @map("average_ticket_brl") @db.Decimal(12, 2)
  /// Próxima oferta sugerida (upsell / motor comercial)
  nextBestOfferSlug     String?  @map("next_best_offer_slug") @db.VarChar(120)
  /// Hash do último IP visto (login / checkout) — não armazenamos IP em claro
  lastSeenIpHash        String?  @map("last_seen_ip_hash") @db.VarChar(64)
  /// Bloqueio automático de nova compra até revisão manual
  riskBlockCheckout     Boolean  @default(false) @map("risk_block_checkout")
  riskBlockReason       String?  @map("risk_block_reason") @db.VarChar(500)

  // CRM — Endereço completo (melhoria 15/04/2026)
  addressZip            String?  @map("address_zip") @db.VarChar(10)       // CEP (00000-000)
  addressStreet         String?  @map("address_street") @db.VarChar(300)   // Logradouro
  addressNumber         String?  @map("address_number") @db.VarChar(20)    // Número
  addressComplement     String?  @map("address_complement") @db.VarChar(100) // Complemento
  addressNeighborhood   String?  @map("address_neighborhood") @db.VarChar(100) // Bairro
  addressCity           String?  @map("address_city") @db.VarChar(100)     // Cidade
  addressState          String?  @map("address_state") @db.VarChar(2)      // UF (ex: SP)

  // CRM — Redes sociais adicionais (melhoria 15/04/2026)
  instagramHandle       String?  @map("instagram_handle") @db.VarChar(64)
  facebookUrl           String?  @map("facebook_url") @db.VarChar(255)
  linkedinUrl           String?  @map("linkedin_url") @db.VarChar(255)

  // CRM — Financeiro / faturamento (melhoria 15/04/2026)
  creditLimit           Decimal? @map("credit_limit") @db.Decimal(12, 2)  // Limite de crédito
  preferredDueDay       Int?     @map("preferred_due_day")                 // Dia de vencimento 1-28

  // CRM — Tags de segmentação (melhoria 15/04/2026)
  // Ex: ["VIP","HIGH_TICKET","CHURN_RISK","BLACK_FRIDAY","UPSELL_CANDIDATE"] — armazenado como JSON (MySQL)
  segmentationTags      Json     @default("[]") @map("segmentation_tags")

  @@index([whatsapp])
  @@index([accountManagerId])
  @@index([trustScore])
  @@index([riskBlockCheckout])
  @@index([addressCity])
  @@index([addressState])
}

/// Hall de patentes — pedidos de resgate de recompensas (logística comercial)
model ClientGamificationRedemption {
  id           String        @id @default(cuid())
  clientId     String        @map("client_id")
  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rewardKey    String        @map("reward_key") @db.VarChar(80)
  requestedAt  DateTime      @default(now()) @map("requested_at")
  fulfilledAt  DateTime?     @map("fulfilled_at")
  /// Endereço e contacto para envio físico (JSON)
  shippingPayload Json?     @map("shipping_payload")

  @@unique([clientId, rewardKey])
  @@index([rewardKey])
  @@map("client_gamification_redemptions")
}

/// Mentorado Ads Ativos — ligação explícita cliente ↔ UNI (permissões War Room).
model ClientMentoradoUniAccess {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uniId     String   @map("uni_id") @db.Char(36)
  uni       VaultIndustrialUnit @relation(fields: [uniId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([clientId, uniId])
  @@index([uniId])
  @@map("client_mentorado_uni_access")
}

/// Histórico append-only — proxies, BMs, padrões de queda (War Room / suporte)
model ClientTechnicalNote {
  id        String        @id @default(cuid())
  clientId  String        @map("client_id")
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String        @map("author_id")
  author    User          @relation(fields: [authorId], references: [id])
  body      String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@map("client_technical_notes")
}

enum ClientNicheTag {
  WHITE
  BLACK
  NUTRA
  CASINO
}

/// Módulo 03 — Creative Vault: nicho do criativo de referência
enum CreativeVaultNiche {
  SAUDE
  FINANCEIRO
  BLACK
  ECOMMERCE
  IGAMING
  EDUCACAO
  GERAL
}

/// Kanban agência interna — personalização de criativos
enum CreativeAgencyJobStatus {
  FILA
  PRODUCAO
  REVISAO
  ENTREGUE
}

// ============ FÁBRICA DE LANDING PAGES & ADS ============

model LandingBriefing {
  id               String   @id @default(cuid())
  clientId         String   @map("client_id")
  client           ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Dados do negócio
  nomeEmpresa      String   @default("") @map("nome_empresa") @db.VarChar(200)
  nomeFantasia     String?  @map("nome_fantasia") @db.VarChar(200)
  nicho            String   @default("") @db.VarChar(200)
  subnicho         String?  @map("subnicho") @db.VarChar(200)
  cidade           String   @default("") @db.VarChar(100)
  estado           String   @default("") @db.VarChar(2)
  cnpj             String?  @db.VarChar(18)
  endereco         String?  @db.VarChar(300)
  telefone         String?  @db.VarChar(20)
  whatsapp         String?  @db.VarChar(20)
  email            String?  @db.VarChar(150)
  horarioAtendimento String? @map("horario_atendimento") @db.VarChar(100)
  // Briefing estratégico
  servicos         String   @default("") @db.Text           // Lista (linha por linha)
  anosExperiencia  Int?     @map("anos_experiencia")
  diferenciais     String?  @db.Text
  objetivo         String?  @db.VarChar(100)   // LIGACOES, WHATSAPP, ORCAMENTO, AGENDAMENTO, PRESENCIAL, OUTRO
  objetivoOutro    String?  @map("objetivo_outro") @db.VarChar(200)
  tipoCliente      String?  @map("tipo_cliente") @db.Text
  problemasDemandas String? @map("problemas_demandas") @db.Text
  perfilCliente    String?  @map("perfil_cliente") @db.Text  // Legado
  restricoes       String?  @db.Text
  // Campos legados (compatibilidade)
  publicoAlvo      String?  @map("publico_alvo") @db.VarChar(500)
  dor              String?  @db.Text
  solucao          String?  @db.Text
  ofertaUnica      String?  @map("oferta_unica") @db.Text
  templateMode     String   @default("WHITE") @map("template_mode") @db.VarChar(16)
  vturbEmbed       String?  @map("vturb_embed") @db.Text
  footerHtml       String?  @map("footer_html") @db.Text
  status           String   @default("DRAFT")    // DRAFT, GERADO, PUBLICADO
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  pages            LandingPage[]

  @@index([clientId])
  @@index([status])
  @@map("landing_briefings")
}

model LandingPage {
  id          String   @id @default(cuid())
  briefingId  String   @map("briefing_id")
  briefing    LandingBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  clientId    String   @map("client_id")
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  html        String   @db.Text
  css         String?  @db.Text
  whatsapp    String?  @map("whatsapp") @db.VarChar(20)
  conversionId String? @map("conversion_id") @db.VarChar(100)  // Google Ads
  conversionLabel String? @map("conversion_label") @db.VarChar(100)
  status      String   @default("GERADO")   // GERADO, PUBLICADO
  templateMode String   @default("WHITE") @map("template_mode") @db.VarChar(16)
  vturbEmbed   String?  @map("vturb_embed") @db.Text
  footerHtml   String?  @map("footer_html") @db.Text
  pageTrackingScript String? @map("page_tracking_script") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  deployments LandingDeployment[]

  @@index([clientId])
  @@index([briefingId])
  @@map("landing_pages")
}

model LandingDomain {
  id              String   @id @default(cuid())
  clientId        String   @map("client_id")
  client          ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domain          String   @unique @db.VarChar(253)
  cloudflareZoneId String? @map("cloudflare_zone_id") @db.VarChar(100)
  sslStatus       String   @default("PENDING") @map("ssl_status") @db.VarChar(20)
  /// Blindagem Traffic Shield / proxy reverso (webhook Gerson)
  shieldEnabled        Boolean   @default(false) @map("shield_enabled")
  shieldRequestedAt    DateTime? @map("shield_requested_at")
  shieldLastWebhookAt  DateTime? @map("shield_last_webhook_at")
  shieldWebhookError   String?   @map("shield_webhook_error") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  deployments     LandingDeployment[]

  @@index([clientId])
  @@map("landing_domains")
}

model LandingDeployment {
  id            String   @id @default(cuid())
  pageId        String   @map("page_id")
  page          LandingPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  domainId      String?  @map("domain_id")
  domain        LandingDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)
  url           String   @db.VarChar(500)
  hospedaRef    String?  @map("hospeda_ref") @db.VarChar(100)
  status        String   @default("PENDING")  // PENDING, DEPLOYING, LIVE, FAILED
  deployedAt    DateTime? @map("deployed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([pageId])
  @@index([domainId])
  @@map("landing_deployments")
}

// ============ PROVISIONAMENTO DE DOMÍNIOS / LANDERS (MASSA) ============

model DomainProvisionBatch {
  id             String   @id @default(cuid())
  createdById    String   @map("created_by_id")
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  targetServerIp String   @map("target_server_ip") @db.VarChar(45)
  templateKey    String   @map("template_key") @db.VarChar(32)
  metaPixelId    String?  @map("meta_pixel_id") @db.VarChar(64)
  videoMasterKey String?  @map("video_master_key") @db.VarChar(120)
  clientId       String?  @map("client_id")
  client         ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status         String   @default("QUEUED") @db.VarChar(20)
  domainsRaw     String   @map("domains_raw") @db.Text
  itemCount      Int      @default(0) @map("item_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  items DomainProvisionItem[]

  @@index([createdById])
  @@index([status, createdAt])
  @@map("domain_provision_batches")
}

model DomainProvisionItem {
  id               String   @id @default(cuid())
  batchId          String   @map("batch_id")
  batch            DomainProvisionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  domain           String   @db.VarChar(253)
  registrarStatus  String   @default("PENDING") @map("registrar_status") @db.VarChar(20)
  cloudflareStatus String   @default("PENDING") @map("cloudflare_status") @db.VarChar(20)
  serverStatus     String   @default("PENDING") @map("server_status") @db.VarChar(20)
  cloudflareZoneId String?  @map("cloudflare_zone_id") @db.VarChar(100)
  videoVariantHash String?  @map("video_variant_hash") @db.VarChar(64)
  publicUrl        String?  @map("public_url") @db.VarChar(500)
  lastError        String?  @map("last_error") @db.Text
  logs             String?  @map("logs") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([batchId, domain])
  @@index([batchId])
  @@map("domain_provision_items")
}

// Reunião de onboarding de cliente novo
model OnboardingMeeting {
  id                   String    @id @default(cuid())
  clientId             String    @map("client_id")
  client               ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title                String    @default("Onboarding Cliente")
  notes                String?   @db.Text
  scheduledAt          DateTime  @map("scheduled_at")
  durationMinutes      Int       @default(30) @map("duration_minutes")
  googleCalendarEventId String?  @map("google_calendar_event_id")
  /// Link Google Meet retornado ao criar o evento (se conferência solicitada na API)
  meetLink             String?   @map("meet_link") @db.VarChar(512)
  status               String    @default("SCHEDULED")  // SCHEDULED, COMPLETED, CANCELLED, RESCHEDULED
  createdById          String?   @map("created_by_id")
  createdBy            User?     @relation("OnboardingMeetingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  participants         OnboardingParticipant[]

  @@index([clientId])
  @@index([scheduledAt, status])
  @@map("onboarding_meetings")
}

// Colaborador participante da reunião de onboarding
model OnboardingParticipant {
  id        String            @id @default(cuid())
  meetingId String            @map("meeting_id")
  meeting   OnboardingMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String            @map("user_id")
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now()) @map("created_at")

  @@unique([meetingId, userId])
  @@index([userId])
  @@map("onboarding_participants")
}

// Solicitação de novas contas (por última compra ou quantidade desejada)
model AccountSolicitation {
  id                String         @id @default(cuid())
  clientId          String         @map("client_id")
  client            ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quantity          Int            @map("quantity")
  product           String
  accountType       String         @map("account_type")
  country           String?
  referenceOrderId  String?        @map("reference_order_id") // se baseado na última compra
  status            String         @default("pending") // pending, in_progress, provisioning, completed, cancelled
  notes             String?        @db.Text
  /// Módulo 02 Armory: GOOGLE_ADS | META_ADS | TIKTOK_ADS
  trafficSource     String?        @map("traffic_source") @db.VarChar(24)
  /// BEGINNER | SCALE | BLACK
  operationLevel    String?        @map("operation_level") @db.VarChar(24)
  /// Checkout para preparar S2S / Tracker
  checkoutUrl       String?        @map("checkout_url") @db.VarChar(2000)
  /// LEGACY (solicitar contas) | ARMORY (Central de Ativos)
  kind              String         @default("LEGACY") @map("kind") @db.VarChar(24)
  expectedDeliveryAt DateTime?     @map("expected_delivery_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@map("account_solicitations")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    @default("GENERIC")  // DAILY_DIGEST, TASK_ALERT, APPROVAL_NEEDED, etc.
  channel   String    @default("IN_APP")   // IN_APP, EMAIL, WHATSAPP
  title     String
  message   String    @db.Text
  metadata  Json?
  read      Boolean   @default(false)
  link      String?
  priority  String    @default("NORMAL")   // LOW, NORMAL, HIGH, URGENT
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([createdAt])
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyDigestAt   String?  @map("daily_digest_at")   // "08:00"
  notifyWhatsapp  Boolean  @default(true) @map("notify_whatsapp")
  notifyEmail     Boolean  @default(true) @map("notify_email")
  notifyInApp     Boolean  @default(true) @map("notify_in_app")
  notifyPush      Boolean  @default(true) @map("notify_push")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  keys      Json     // { p256dh, auth }
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, endpoint(length: 191)])
  @@index([userId])
  @@map("push_subscriptions")
}

model ManagerProfile {
  id       String @id @default(cuid())
  userId   String @unique @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts StockAccount[]
}

// ============ PAÍSES E MOEDAS ============

model Country {
  id             String   @id @default(cuid())
  code           String   @unique  // ISO 3166-1 alpha-2 (BR, US, MX, AR, etc.)
  name           String
  currency       String   // BRL, USD, MXN, ARS, EUR...
  currencySymbol String   @map("currency_symbol") // R$, $, etc.
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  emails          Email[]
  cnpjs           Cnpj[]
  paymentProfiles PaymentProfile[]
  niches          Niche[]
}

model Niche {
  id          String   @id @default(cuid())
  countryId   String   @map("country_id")
  country     Country  @relation(fields: [countryId], references: [id])
  name        String   // Ex: Nutra, E-commerce, Infoprodutos
  cnaePattern String?  @map("cnae_pattern") @db.Text // Padrão CNAE ou equivalente para filtro
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  cnpjs Cnpj[]
}

// ============ STATUS DE ITENS DE ESTOQUE ============

enum StockItemStatus {
  AVAILABLE  // Disponível para reserva
  RESERVED   // Reservado para um produtor (não pode ir para outro)
  CONSUMED   // Já utilizado em uma conta (nunca mais reutilizar)
  DISABLED   // Desativado/inutilizável
}

// ============ PRODUÇÃO E ESTOQUE ============

enum AccountPlatform {
  GOOGLE_ADS
  META_ADS
  KWAI_ADS
  TIKTOK_ADS
  OTHER
}

enum AccountStatus {
  PENDING
  IN_ANALYSIS
  UNDER_REVIEW
  QUARANTINE
  APPROVED
  REJECTED
  IN_USE
  AVAILABLE
  CRITICAL
  DELIVERED
  DEAD
}

enum WarmupStatus {
  NORMAL
  WARM_UP
  READY_TO_SCALE
  FLAGGED
}

model ProductionAccount {
  id                  String         @id @default(cuid())
  platform            AccountPlatform
  type                String
  /// Identificador operacional único (lista / PDF / referência interna)
  accountCode         String?        @unique @map("account_code") @db.VarChar(120)
  passwordHash        String?        @map("password_hash") @db.Text
  email               String?
  cnpj                String?
  countryId           String?        @map("country_id")
  status              AccountStatus  @default(PENDING)
  rejectionReason     String?        @map("rejection_reason") @db.Text
  rejectionReasonCode String?        @map("rejection_reason_code") // Código para agregação: DOC_INVALIDO, EMAIL_BLOQUEADO, etc.
  producerId          String         @map("producer_id")
  producer            User           @relation(fields: [producerId], references: [id])
  stockAccountId      String?        @unique @map("stock_account_id")
  stockAccount        StockAccount?  @relation(fields: [stockAccountId], references: [id])
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Campos extras - Passo 2 melhoria
  googleAdsCustomerId String?        @map("google_ads_customer_id") // Formato 000-000-0000
  currency            String?        @default("BRL") @db.VarChar(5) // BRL, USD, EUR, etc.
  a2fCode             String?        @map("a2f_code") @db.Text
  g2ApprovalCode      String?        @map("g2_approval_code") @db.VarChar(100)
  siteUrl             String?        @map("site_url") @db.Text
  cnpjBizLink         String?        @map("cnpj_biz_link") @db.Text
  cnpjPdfUrl          String?        @map("cnpj_pdf_url") @db.Text // Path ou URL do PDF
  passwordPlain       String?        @map("password_plain") @db.Text // Senha de acesso à conta

  // ADS CORE — nicho, meta de verificação, footprint
  productionNiche     String         @default("OTHER") @map("production_niche") @db.VarChar(32)
  verificationGoal    String         @default("G2_AND_ADVERTISER") @map("verification_goal") @db.VarChar(48)
  primaryDomain       String?        @unique @map("primary_domain") @db.VarChar(253)
  proxyNote           String?        @map("proxy_note") @db.VarChar(500)
  proxyConfigured     Boolean        @default(false) @map("proxy_configured")

  // Referências aos dados consumidos (unicidade - nunca reutilizar)
  emailId             String?        @unique @map("email_id")
  emailConsumed       Email?         @relation(fields: [emailId], references: [id])
  cnpjId              String?        @unique @map("cnpj_id")
  cnpjConsumed        Cnpj?          @relation(fields: [cnpjId], references: [id])
  paymentProfileId    String?        @unique @map("payment_profile_id")
  paymentProfileConsumed PaymentProfile? @relation(fields: [paymentProfileId], references: [id])

  checklist           ProductionChecklist[]
  deletedAt           DateTime? @map("deleted_at")   // Soft delete: nunca apagar

  validatedByManagerId String?   @map("validated_by_manager_id")  // Gerente que conferiu
  validatedByManager   User?     @relation("ProductionAccountValidatedBy", fields: [validatedByManagerId], references: [id])
  validatedAt          DateTime? @map("validated_at")             // Momento da conferência (conta para pagamento)

  // Melhoria 15/04/2026 — Checkpoint de Auditoria
  productionCost      Decimal?       @map("production_cost") @db.Decimal(10, 2) // Custo real (chip + proxy + contingência) para ROI
  warmupStatus        WarmupStatus   @default(NORMAL) @map("warmup_status")     // Ready to Scale / Warm-up / Flagged / Normal
  quarantineUntil     DateTime?      @map("quarantine_until")                    // Conta liberada ao estoque só após esta data/hora
  quarantineHours     Int?           @map("quarantine_hours")                    // Horas configuradas de quarentena (ex: 48)
  deadAt              DateTime?      @map("dead_at")                             // Dead Switch: quando conta foi baixada
  deadReason          String?        @map("dead_reason") @db.VarChar(500)        // Motivo: Checkpoint Inicial, Ban, etc.

  @@index([producerId, status, createdAt])
  @@index([validatedAt])
  @@index([deletedAt])
  @@index([warmupStatus])
  @@index([quarantineUntil])
}

// Checklist para mitigar erros na produção (produtor marca antes de enviar)
model ProductionChecklist {
  id          String            @id @default(cuid())
  accountId   String            @map("account_id")
  account     ProductionAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  stepType    String            @map("step_type") // EMAIL_OK, CNPJ_OK, PAGAMENTO_OK, PLATAFORMA_CRIADA, DADOS_VERIFICADOS
  completed   Boolean           @default(false)
  completedAt DateTime?         @map("completed_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  @@unique([accountId, stepType])
  @@map("production_checklists")
}

model StockAccount {
  id                    String         @id @default(cuid())
  platform              AccountPlatform
  type                  String
  source                String?        @default("PRODUCTION")  // PRODUCTION, PRODUCTION_G2, IMPORT, MANUAL
  archivedAt            DateTime?      @map("archived_at")    // Preenchido = em vault (não vende). Null = disponível
  deletedAt             DateTime?      @map("deleted_at")     // Soft delete: nunca apagar. Null = ativo.
  countryId             String?        @map("country_id")
  yearStarted           Int?           @map("year_started")
  niche                 String?
  minConsumed           Decimal?       @map("min_consumed") @db.Decimal(12, 2)
  limitUsage            Decimal?       @map("limit_usage") @db.Decimal(12, 2)
  spent                 Decimal?       @db.Decimal(12, 2)
  status                AccountStatus  @default(AVAILABLE)
  clientId              String?        @map("client_id")
  client                ClientProfile? @relation("ClientAccounts", fields: [clientId], references: [id])
  googleAdsCustomerId   String?        @map("google_ads_customer_id") // 123-456-7890 para API
  margin                Decimal?       @db.Decimal(8, 2)
  managerId             String?        @map("manager_id")
  manager               ManagerProfile? @relation(fields: [managerId], references: [id])
  supplierId            String?        @map("supplier_id")
  supplier              Supplier?      @relation(fields: [supplierId], references: [id])
  purchasePrice         Decimal?       @map("purchase_price") @db.Decimal(12, 2)
  salePrice             Decimal?       @map("sale_price") @db.Decimal(12, 2)
  markupPercent         Decimal?       @map("markup_percent") @db.Decimal(5, 2)
  description           String?        @db.Text
  deliveredAt           DateTime?      @map("delivered_at")
  /// Chargeback / fraude: conta marcada para bloqueio operacional
  compromisedAt         DateTime?      @map("compromised_at")
  compromiseReason      String?        @map("compromise_reason") @db.VarChar(64)
  lastSpendSyncAt       DateTime?      @map("last_spend_sync_at")
  /// Spend exibido na vitrine (moeda original USD/EUR) — fechamento continua em BRL (salePrice)
  spentDisplayCurrency  String?        @map("spent_display_currency") @db.VarChar(8)
  spentDisplayAmount    Decimal?       @map("spent_display_amount") @db.Decimal(14, 2)
  /// Selo digital "Ativo Verificado Ads Ativos" (listagens / Telegram)
  adsAtivosVerified     Boolean        @default(true) @map("ads_ativos_verified")
  isPlugPlay            Boolean        @default(false) @map("is_plug_play") // G2 + 1ª campanha White aprovada
  /// UNI operacional (Módulo 02 — mentorado); preenchido pela equipa na entrega quando aplicável.
  mentoradoLinkedUniId  String?        @map("mentorado_linked_uni_id") @db.Char(36)
  mentoradoLinkedUni    VaultIndustrialUnit? @relation("StockAccountMentoradoUni", fields: [mentoradoLinkedUniId], references: [id], onDelete: SetNull)
  /// Log de aquecimento exibido ao mentorado (JSON array de { t, msg }).
  mentoradoWarmupLogJson Json?       @map("mentorado_warmup_log_json")
  productionAccount     ProductionAccount?
  productionG2          ProductionG2?
  credential            StockAccountCredential?  // Credenciais de importação (quando não vem de ProductionG2)
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  orderItems         OrderItem[]
  emails             Email[]
  cnpjs              Cnpj[]
  paymentProfiles    PaymentProfile[]
  quotations         Quotation[]
  spendLogs          AccountSpendLog[]
  contestationTickets ContestationTicket[]
  rmaAsOriginal       AccountReplacementRequest[] @relation("RmaOriginalAccount")
  rmaAsReplacement    AccountReplacementRequest[] @relation("RmaReplacementAccount")
  rentedPhones        RentedPhoneNumber[]
  syntheticConversionIntents SyntheticConversionIntent[]
  complianceRiskScore     Int?      @map("compliance_risk_score")
  complianceScannedAt     DateTime? @map("compliance_scanned_at")
  complianceScanSummary   Json?     @map("compliance_scan_summary")
  /// Conferência admin em ofertas de gestor (checklist, notas). Não misturar com compliance de Ads Core.
  offerReviewMeta         Json?     @map("offer_review_meta")
  complianceHistories     ComplianceHistory[]

  @@index([status, platform, countryId])
  @@index([clientId])
  @@index([managerId])
  @@index([mentoradoLinkedUniId])
  @@index([archivedAt])
  @@index([source])
  @@index([deletedAt])
}

// Credenciais de conta (importação manual / migração de AdsPower)
model StockAccountCredential {
  id                  String       @id @default(cuid())
  stockAccountId      String       @unique @map("stock_account_id")
  stockAccount        StockAccount @relation(fields: [stockAccountId], references: [id], onDelete: Cascade)
  email               String?      @db.Text
  passwordEncrypted   String?      @map("password_encrypted") @db.Text
  recoveryEmail       String?      @map("recovery_email")
  twoFaSecret         String?      @map("two_fa_secret") @db.Text
  twoFaSms            String?      @map("two_fa_sms")
  googleAdsCustomerId String?      @map("google_ads_customer_id")
  metaBusinessId      String?      @map("meta_business_id")
  proxyConfig         Json?        @map("proxy_config")
  notes               String?      @db.Text
  deletedAt           DateTime?    @map("deleted_at")  // Soft delete: nunca apagar
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([deletedAt])
  @@map("stock_account_credentials")
}

// Número de telefone alugado via API (5sim etc.) para validação SMS (Google, etc.)
model RentedPhoneNumber {
  id               String       @id @default(cuid())
  stockAccountId   String?      @map("stock_account_id")
  stockAccount     StockAccount? @relation(fields: [stockAccountId], references: [id], onDelete: SetNull)
  productionG2Id   String?      @map("production_g2_id")
  productionG2     ProductionG2? @relation(fields: [productionG2Id], references: [id], onDelete: SetNull)
  phoneNumber      String       @map("phone_number")   // +5511999999999
  country          String       // ex: brazil, england
  operator         String?      // ex: vodafone
  service          String       @default("google")    // google, telegram, etc.
  provider         String       @default("5sim")     // 5sim, etc.
  providerOrderId  String?      @map("provider_order_id")
  status           String       @default("ACTIVE")   // ACTIVE, RELEASED, EXPIRED
  expiresAt        DateTime?    @map("expires_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  smsInbox         SmsInbox[]

  @@index([stockAccountId, status])
  @@index([productionG2Id, status])
  @@index([status])
  @@map("rented_phone_numbers")
}

// SMS recebidos em número alugado (códigos de validação Google, etc.)
model SmsInbox {
  id             String            @id @default(cuid())
  rentedPhoneId  String            @map("rented_phone_id")
  rentedPhone    RentedPhoneNumber @relation(fields: [rentedPhoneId], references: [id], onDelete: Cascade)
  sender         String?           // remetente
  body           String            @db.Text
  code           String?           // código extraído (ex: 6 dígitos)
  receivedAt     DateTime?         @map("received_at") // quando a API recebeu
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([rentedPhoneId])
  @@map("sms_inbox")
}

// Histórico de uploads de contas (arquivo)
model AccountArchiveBatch {
  id           String   @id @default(cuid())
  filename     String   @map("filename")
  format       String   // CSV, JSON
  uploadedById String   @map("uploaded_by_id")
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  totalRows    Int      @map("total_rows")
  imported     Int      @default(0)
  failed       Int      @default(0)
  duplicate    Int      @default(0) @map("duplicate")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([uploadedById])
  @@index([createdAt])
  @@map("account_archive_batches")
}

// Gastos por conta (sync via Google Ads API)
model AccountSpendLog {
  id            String       @id @default(cuid())
  accountId     String       @map("account_id")
  account       StockAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart   DateTime     @map("period_start") // início do período (ex: 1º do mês)
  periodEnd     DateTime     @map("period_end")
  costMicros    BigInt       @map("cost_micros") // cost em micros (÷ 1_000_000)
  impressions   Int          @default(0)
  clicks        Int          @default(0)
  conversions   Int          @default(0) @map("conversions")
  currencyCode  String?      @map("currency_code")
  syncedAt      DateTime     @default(now()) @map("synced_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@unique([accountId, periodStart])
  @@map("account_spend_logs")
}

// Tickets de contestação e operações comerciais
enum ContestationType {
  BAN_CONTESTATION    // Conta banida - contestar
  REPLACEMENT_REQUEST // Solicitar reposição
  PAUSED_NEEDS_OPS    // Conta pausada - precisa operação comercial
}

enum ContestationStatus {
  OPEN
  IN_REVIEW
  REPLACEMENT_APPROVED
  RESOLVED
  REJECTED
}

model ContestationTicket {
  id                    String            @id @default(cuid())
  clientId              String            @map("client_id")
  client                ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  accountId             String            @map("account_id")
  account               StockAccount      @relation(fields: [accountId], references: [id])
  type                  ContestationType
  status                ContestationStatus @default(OPEN)
  priority              String            @default("NORMAL")  // LOW, NORMAL, HIGH, URGENT
  slaResponseAt         DateTime?         @map("sla_response_at")  // Prazo primeira resposta
  slaResolveAt          DateTime?         @map("sla_resolve_at")   // Prazo resolução
  banReason             String?           @map("ban_reason") @db.Text
  description           String            @db.Text
  needsReplacement      Boolean           @default(false) @map("needs_replacement")
  commercialOpsRequested Boolean          @default(false) @map("commercial_ops_requested")
  accountReturned       Boolean?          @map("account_returned") // se a conta voltou
  resolutionNotes       String?           @map("resolution_notes") @db.Text
  resolvedAt            DateTime?         @map("resolved_at")
  resolvedById          String?           @map("resolved_by_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([status, priority])
  @@map("contestation_tickets")
}

/// RMA Plug & Play — reposição de conta (tb_reposicoes)
enum AccountRmaStatus {
  EM_ANALISE
  EM_REPOSICAO
  CONCLUIDO
  NEGADO_TERMO
}

enum AccountRmaReason {
  ERRO_CONFIGURACAO
  FALHA_ATIVACAO
  SUSPENSAO_IMEDIATA
  LOGIN_INVALIDO
  CHECKPOINT_BLOCK
  BAN_IMMEDIATE
  PROXY_ERROR
  OUTRO
}

model AccountReplacementRequest {
  id                   String           @id @default(cuid())
  clientId             String           @map("client_id")
  client               ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  /// Venda de origem (garantia / rastreio)
  orderId              String?          @map("order_id")
  order                Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  originalAccountId    String           @map("id_conta_original")
  originalAccount      StockAccount     @relation("RmaOriginalAccount", fields: [originalAccountId], references: [id])
  replacementAccountId String?          @map("id_nova_conta")
  replacementAccount   StockAccount?    @relation("RmaReplacementAccount", fields: [replacementAccountId], references: [id])
  reason               AccountRmaReason   @map("motivo_id")
  reasonDetail         String?          @db.Text
  evidenceUrls         Json?            @map("evidencia_url")
  additionalComments   String?          @map("comentarios") @db.Text
  status               AccountRmaStatus   @default(EM_ANALISE)
  openedAt             DateTime         @default(now()) @map("opened_at")
  resolvedAt           DateTime?        @map("resolved_at")
  resolutionMinutes    Int?             @map("tempo_resolucao")
  assignedToId         String?          @map("assigned_to_id")
  assignedTo           User?            @relation("RmaAssignedTo", fields: [assignedToId], references: [id])
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  messages RmaMessage[]

  @@index([clientId])
