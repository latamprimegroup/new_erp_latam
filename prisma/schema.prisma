enum BlackOperationStatus {
  DRAFT
  EM_AQUECIMENTO
  EM_CONFIG
  LIVE
  SURVIVED_24H
  BANNED
}

/// Classificação para contestação em queda técnica (proxy vs credencial)
enum BlackTechnicalBanReason {
  PROXY
  LOGIN
}

enum BlackStepType {
  AQUECIMENTO_G2
  DOMINIO_NICHO
  AQUECIMENTO_CONTA
  CLOAKER
  PAGINA_WHITE
  PAGINA_BLACK
  YOUTUBE_CANAL
  CRIATIVO_BLACK
}

model BlackOperation {
  id              String              @id @default(cuid())
  collaboratorId  String              @map("collaborator_id")
  collaborator    User                @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  niche           String
  domain          String?
  stockAccountId  String?             @map("stock_account_id")
  /// GOOGLE_ADS | FACEBOOK (comissão unitária diferenciada)
  platform        String?             @map("platform")
  status          BlackOperationStatus @default(DRAFT)
  wentLiveAt      DateTime?           @map("went_live_at")
  bannedAt        DateTime?           @map("banned_at")
  technicalBanReason BlackTechnicalBanReason? @map("technical_ban_reason")
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  steps     BlackOperationStep[]
  payment   BlackPayment?
}

model BlackOperationStep {
  id          String       @id @default(cuid())
  operationId String       @map("operation_id")
