// ============ GATEKEEPER / COFRE — INGESTÃO BLINDADA (MÓDULO 01 WAR ROOM OS) ============
// Único ponto de entrada de ativos sensíveis: EXIF strip, unicidade cruzada, cifra em repouso.

enum VaultGmailStatus {
  AVAILABLE
  IN_USE
  BURNED
}

enum VaultCardStatus {
  AVAILABLE
  IN_USE
  BURNED
}

/// Gmails do cofre (separado do legado Email — promovível depois via pipeline).
model InventoryGmail {
  id               String          @id @default(uuid()) @db.Char(36)
  email            String          @unique @db.VarChar(320)
  passwordEnc      String          @map("password_enc") @db.Text
  /// E-mail de recuperação (cifrado em repouso).
  recoveryEmailEnc String?        @map("recovery_email_enc") @db.Text
  /// Ano de safra do ativo (ex.: 2014) — métricas tipo Vovô (mais de 10 anos).
  harvestYear      Int?            @map("harvest_year")
  /// JSON cifrado em repouso (serializado + AES-256-GCM via lib/encryption).
  sessionCookiesEnc String?        @map("session_cookies") @db.Text
  gmailSafra       String?         @map("gmail_safra") @db.VarChar(64)
  status           VaultGmailStatus @default(AVAILABLE) @map("status")
  twoFaEnc         String?         @map("two_fa_enc") @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  vaultIndustrialUnits VaultIndustrialUnit[]

  @@index([status])
  @@map("inventory_gmails")
}

/// Identidades (CPF + documentos) — photoHash impede reuso da mesma foto processada.
model InventoryId {
  id         String   @id @default(uuid()) @db.Char(36)
  fullName   String   @map("full_name") @db.VarChar(300)
  cpf        String   @unique @db.VarChar(14)
  /// Lista de referências de armazenamento (paths internos / keys), JSON.
  docUrls    Json?    @map("doc_urls")
  photoHash  String   @unique @map("photo_hash") @db.VarChar(32)
  /// Nome do sócio / representante (Geo-Provision / G-Pay).
  partnerLegalName String?   @map("partner_legal_name") @db.VarChar(300)
  partnerBirthDate DateTime? @map("partner_birth_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  vaultIndustrialUnits VaultIndustrialUnit[]

  @@map("inventory_ids")
}

/// CNPJs do cofre; nicho inferido a partir do CNAE na ingestão (Brasil API).
model InventoryCnpj {
  id            String   @id @default(uuid()) @db.Char(36)
  cnpj          String   @unique @db.VarChar(14)
  razaoSocial   String?  @map("razao_social") @db.VarChar(500)
  cnae          String?  @db.VarChar(20)
  nicheInferred String?  @map("niche_inferred") @db.VarChar(120)
  /// Tag manual do operador (Nutra, Estética, …) — prevalece na UI sobre a inferida por CNAE.
  nicheOperatorTag String? @map("niche_operator_tag") @db.VarChar(120)
  /// { cidade, estado, cep }
  geofencing    Json?    @map("geofencing")
  situacaoRf    String?  @map("situacao_rf") @db.VarChar(40)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vaultIndustrialUnits VaultIndustrialUnit[]

  @@map("inventory_cnpjs")
}

/// Cartões: unicidade por hash determinístico do PAN; PAN cifrado em repouso.
model InventoryCard {
  id           String          @id @default(uuid()) @db.Char(36)
  cardPanHash  String          @unique @map("card_pan_hash") @db.VarChar(64)
  cardPanEnc   String          @map("card_pan_enc") @db.Text
  holderName   String?         @map("holder_name") @db.VarChar(200)
  status       VaultCardStatus @default(AVAILABLE) @map("status")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@map("inventory_cards")
}

// ============ GEO-PROVISION (MÓDULO 02) — AdsPower + proxy geográfico + UNI ============

/// Lotes operacionais (Módulo 4 — escala / processo). Progresso é interno ao ERP, não “trust score” de terceiros.
enum WarmupLotStatus {
  PLANNING
  ACTIVE
  PAUSED
  ARCHIVED
}

model WarmupLot {
  id                   String          @id @default(cuid())
  name                 String          @db.VarChar(200)
  nicheTag             String?         @map("niche_tag") @db.VarChar(120)
  status               WarmupLotStatus @default(PLANNING)
  /// Maturação operacional 0–100 (definida pelo gestor; métricas reais podem alimentar depois).
  internalMaturityPct  Int             @default(0) @map("internal_maturity_pct")
  notes                String?         @db.Text
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  units VaultIndustrialUnit[]

  @@index([status])
  @@map("warmup_lots")
}

enum VaultIndustrialUnitStatus {
  DRAFT
  PROVISIONING
  READY_FOR_WARMUP
  FAILED
}

/// Pool de proxies para ancoragem por cidade/UF/DDD (Bright Data / Asdl / manual).
model GeoProxyPoolEntry {
  id               String   @id @default(cuid())
  provider         String   @db.VarChar(32)
  label            String?  @db.VarChar(120)
  city             String?  @db.VarChar(120)
  stateUf          String?  @map("state_uf") @db.VarChar(4)
  ddd              String?  @db.VarChar(3)
  proxyHost        String   @map("proxy_host") @db.VarChar(255)
  proxyPort        String   @map("proxy_port") @db.VarChar(8)
  proxyUser        String?  @map("proxy_user") @db.VarChar(200)
  proxyPasswordEnc String?  @map("proxy_password_enc") @db.Text
  /// luminati | oxylabs | other — repasse ao AdsPower user_proxy_config.proxy_soft
  proxySoft        String?  @map("proxy_soft") @db.VarChar(32)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  matchedUnits VaultIndustrialUnit[]

  @@index([active, city])
  @@index([active, stateUf])
  @@map("geo_proxy_pool")
}

/// UNI — unidade industrial: Gmail + CNPJ do cofre (+ identidade opcional) → perfil AdsPower.
model VaultIndustrialUnit {
  id                String                    @id @default(uuid()) @db.Char(36)
  inventoryGmailId  String                    @map("inventory_gmail_id") @db.Char(36)
  inventoryGmail    InventoryGmail            @relation(fields: [inventoryGmailId], references: [id])
  inventoryCnpjId   String                    @map("inventory_cnpj_id") @db.Char(36)
  inventoryCnpj     InventoryCnpj           @relation(fields: [inventoryCnpjId], references: [id])
  identityInventoryId String?               @map("inventory_id_id") @db.Char(36)
  identityInventory   InventoryId?          @relation(fields: [identityInventoryId], references: [id])

  adsPowerProfileId String?                   @map("ads_power_profile_id") @db.VarChar(64)
  status            VaultIndustrialUnitStatus @default(DRAFT)
  /// Protocolo de viagem 48h — proxy no estado, não na cidade exata.
  geoTransition     Boolean                   @default(false) @map("geo_transition")
  anchorCity        String?                   @map("anchor_city") @db.VarChar(120)
  anchorState       String?                   @map("anchor_state") @db.VarChar(4)
  matchedProxyId    String?                   @map("matched_proxy_id")
  matchedProxy      GeoProxyPoolEntry?        @relation(fields: [matchedProxyId], references: [id])
  lastPipelineLogs  Json?                     @map("last_pipeline_logs")
  provisionError    String?                   @map("provision_error") @db.Text
  warmupLotId       String?                   @map("warmup_lot_id")
  warmupLot         WarmupLot?                @relation(fields: [warmupLotId], references: [id], onDelete: SetNull)

  /// Nome operacional (ex.: Operação Nutra — Conta 05).
  displayName       String?                   @map("display_name") @db.VarChar(200)
  /// Domínio “cara” exclusivo planejado para esta UNI (validação suave vs campanhas).
  primaryDomainHost String?                   @map("primary_domain_host") @db.VarChar(253)
  timezoneIana      String?                   @map("timezone_iana") @db.VarChar(64)
  preferredLocale   String?                   @map("preferred_locale") @db.VarChar(24)
  /// Overrides de cabeçalhos para o edge (Accept-Language, hints; contrato com Gerson).
  customHeadersJson Json?                   @map("custom_headers_json")
  /// Nível de risco operacional (manual ou derivado na UI).
  riskLevel         String                    @default("MEDIUM") @map("risk_level") @db.VarChar(16)
  /// Kill-switch: UNI isolada de operação; proxy desativado no pool.
  killedAt          DateTime?                 @map("killed_at")
  killedReason      String?                   @map("killed_reason") @db.VarChar(500)
  lastProxyProbeAt  DateTime?                 @map("last_proxy_probe_at")
  lastProxyProbeOk  Boolean?                  @map("last_proxy_probe_ok")
  lastProxyProbeMs  Int?                      @map("last_proxy_probe_ms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([inventoryGmailId])
  @@index([warmupLotId])
  @@index([primaryDomainHost])
  adsTrackerCampaigns   AdsTrackerCampaign[]
  affiliateWebhookEvents AffiliateWebhookEvent[]
  trafficShieldAccessLogs TrafficShieldAccessLog[]
  activityLogs          VaultIndustrialUnitActivityLog[]
  mentoradoUniAccesses  ClientMentoradoUniAccess[]
  mentoradoLinkedStockAccounts StockAccount[] @relation("StockAccountMentoradoUni")
  mentoradoShieldTrackerLinks MentoradoShieldTrackerLink[]

  @@map("vault_industrial_units")
}

model VaultIndustrialUnitActivityLog {
  id        String              @id @default(cuid())
  uniId     String              @map("uni_id") @db.Char(36)
  uni       VaultIndustrialUnit @relation(fields: [uniId], references: [id], onDelete: Cascade)
  kind      String              @db.VarChar(32)
  message   String              @db.VarChar(500)
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([uniId, createdAt])
  @@map("vault_industrial_unit_activity_logs")
}

// ============ ADS ATIVOS TRACKER — Módulo 01: Central de Campanhas ============

enum AdsTrackerCampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

/// Campanha rastreada: vínculo obrigatório a UNI + URL de destino; métricas operacionais no ERP.
model AdsTrackerCampaign {
  id                      String                   @id @default(cuid())
  name                    String                   @db.VarChar(300)
  uniId                   String                   @map("uni_id") @db.Char(36)
  uni                     VaultIndustrialUnit      @relation(fields: [uniId], references: [id], onDelete: Restrict)
  /// URL completa usada para ping de latência e checagens.
  landingUrl              String                   @map("landing_url") @db.VarChar(2000)
  /// Host normalizado (ex.: lander.example.com) para detetar partilha entre campanhas.
  domainHost              String                   @map("domain_host") @db.VarChar(253)
  /// Snapshot proxy no momento da gravação: "host:port" ou host.
  proxyHostKey            String?                  @map("proxy_host_key") @db.VarChar(400)
  gclidTrackingRequired   Boolean                  @default(false) @map("gclid_tracking_required")
  status                  AdsTrackerCampaignStatus @default(ACTIVE)
  /// Contingência operacional (aciona webhook opcional; não descreve conteúdo servido no edge).
  emergencyContingency    Boolean                  @default(false) @map("emergency_contingency")
  clickTotal              Int                      @default(0) @map("click_total")
  gclidCaptured           Int                      @default(0) @map("gclid_captured")
  lastLatencyMs           Int?                     @map("last_latency_ms")
  lastLatencyCheckedAt    DateTime?                @map("last_latency_checked_at")
  /// Google Safe Browsing (malware/phishing) — não equivale a “flag Ads”.
  safeBrowsingStatus      String?                  @map("safe_browsing_status") @db.VarChar(32)
  safeBrowsingDetail      String?                  @map("safe_browsing_detail") @db.VarChar(500)
  safeBrowsingCheckedAt   DateTime?                @map("safe_browsing_checked_at")
  /// Webhook por campanha (sobrescreve variável global do .env, se definido).
  edgeWebhookOverrideUrl  String?                  @map("edge_webhook_override_url") @db.VarChar(800)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([domainHost])
  @@index([proxyHostKey])
  @@index([uniId])
  @@index([status])
  @@map("ads_tracker_campaigns")
}

// ============ ADS TRACKER — Módulo 04: Cofre de landings (operacional; sem cloaking) ============

enum TrackerLandingVaultStack {
  HTML_PLAIN
  WORDPRESS
  ELEMENTOR
  OTHER
}

enum TrackerLandingVaultStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

/// Repositório interno de destinos. Ambas as URLs devem respeitar as políticas das plataformas de anúncios.
model TrackerLandingVault {
  id                   String                   @id @default(cuid())
  name                 String                   @db.VarChar(200)
  /// Destino principal (campanhas / links curtos).
  primaryUrl           String                   @map("primary_url") @db.VarChar(2000)
  /// Destino secundário (institucional, homologação, espelho) — não implica entrega diferente por visitante.
  secondaryUrl         String?                  @map("secondary_url") @db.VarChar(2000)
  stack                TrackerLandingVaultStack @default(HTML_PLAIN)
  status               TrackerLandingVaultStatus @default(DRAFT)
  /// Tempo de resposta HTTP medido no servidor (aproximação; não é LCP real do browser).
  lastProbeMsPrimary   Int?                     @map("last_probe_ms_primary")
  lastProbeMsSecondary Int?                     @map("last_probe_ms_secondary")
  lastProbeAt          DateTime?                @map("last_probe_at")
  /// Notas de higiene (scripts de terceiros, PII em querystring, etc.).
  scriptHygieneNotes   String?                  @map("script_hygiene_notes") @db.Text
  /// Snapshot manual / futura integração (JSON livre).
  conversionSnapshot   Json?                    @map("conversion_snapshot")
  opsNotes             String?                  @map("ops_notes") @db.VarChar(800)
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  tokens     TrackerLandingToken[]
  migrations TrackerLandingDomainMigration[]

  @@index([status])
  @@map("tracker_landing_vault")
}

model TrackerLandingToken {
  id        String              @id @default(cuid())
  vaultId   String              @map("vault_id")
  vault     TrackerLandingVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  token     String              @unique @db.VarChar(64)
  expiresAt DateTime?           @map("expires_at")
  active    Boolean             @default(true)
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([vaultId])
  @@index([token, active])
  @@map("tracker_landing_tokens")
}

model TrackerLandingDomainMigration {
  id        String              @id @default(cuid())
  vaultId   String              @map("vault_id")
  vault     TrackerLandingVault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  fromHost  String              @map("from_host") @db.VarChar(253)
  toHost    String              @map("to_host") @db.VarChar(253)
  note      String?             @db.VarChar(500)
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([vaultId])
  @@map("tracker_landing_domain_migrations")
}

// ============ ADS TRACKER — Módulo 05: Ofertas S2S (postback servidor) ============

enum TrackerOfferPlatform {
  KIWIFY
  HOTMART
  EDUZZ
  KIRVANO
  PERFECT_PAY
  OTHER
}

enum TrackerOfferStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TrackerSalePaymentState {
  APPROVED
  BOLETO_PENDING
  PIX_PENDING
  CHARGEBACK
  REFUNDED
  UNKNOWN
}

enum TrackerOfferIpTrust {
  ALLOWLIST_DISABLED
  ALLOWLIST_OK
  ALLOWLIST_FAIL
}

/// Oferta com postback S2S e link de checkout rastreado no domínio da app (`/pay/{paySlug}`).
model TrackerOffer {
  id                        String                   @id @default(cuid())
  name                      String                   @db.VarChar(200)
  platform                  TrackerOfferPlatform     @default(OTHER)
  status                    TrackerOfferStatus       @default(ACTIVE)
  /// Token opaco na URL do webhook público (não expor o id interno).
  postbackPublicToken       String                   @unique @map("postback_public_token") @db.VarChar(48)
  /// Segredo para HMAC opcional (corpo bruto) — tratar como credencial.
  webhookSecret             String                   @map("webhook_secret") @db.VarChar(128)
  /// Campo JSON para o click id (ex.: gclid, data.xcid) ou "auto" para heurística.
  clickIdField              String                   @default("auto") @map("click_id_field") @db.VarChar(120)
  checkoutTargetUrl         String                   @map("checkout_target_url") @db.VarChar(2000)
  /// Slug único para GET /pay/{paySlug} → redireciona para checkoutTargetUrl.
  paySlug                   String                   @unique @map("pay_slug") @db.VarChar(80)
  /// Minutos a aguardar antes de tentar enviar conversão offline ao Google (fila / antifraude).
  googleOfflineDelayMinutes Int                      @default(120) @map("google_offline_delay_minutes")
  /// Valor bruto de referência (BRL) para alertas de inconsistência no Módulo 10 (opcional).
  referenceGrossBrl         Decimal?                 @map("reference_gross_brl") @db.Decimal(14, 2)
  lastWebhookAt             DateTime?                @map("last_webhook_at")
  lastWebhookOk             Boolean?                 @map("last_webhook_ok")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  signals             TrackerOfferSaleSignal[]
  checkoutSettings    TrackerCheckoutSettings?
  checkoutInitiations TrackerCheckoutInitiation[]
  checkoutAccessTokens TrackerCheckoutAccessToken[]
  conversionRules      TrackerConversionRule[]
  mentoradoShieldLink  MentoradoShieldTrackerLink?
  /// Módulo 07 — Live Proof Labs (oferta interna de referência; sem vínculo mentorado)
  liveProofLabCase     LiveProofLabCase?

  @@index([status])
  @@map("tracker_offers")
}

/// Módulo 04 — mentorado: UNI + destino checkout/VSL + oferta S2S (`/pay` + webhook).
model MentoradoShieldTrackerLink {
  id               String   @id @default(cuid())
  clientId         String   @map("client_id")
  client           ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uniId            String   @map("uni_id") @db.Char(36)
  uni              VaultIndustrialUnit @relation(fields: [uniId], references: [id], onDelete: Restrict)
  label            String?  @db.VarChar(200)
  destinationUrl   String   @map("destination_url") @db.VarChar(2000)
  /// Nicho para política no edge (ex.: SAUDE, FINANCEIRO, BLACK) — `shield_ctx` na URL.
  protectionNiche  String   @map("protection_niche") @db.VarChar(48)
  /// SAFE = página segura (pré-oferta); MONEY = oferta/checkout.
  shieldProfile    String   @map("shield_profile") @db.VarChar(16)
  offerId          String   @unique @map("offer_id")
  offer            TrackerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([uniId])
  @@map("mentorado_shield_tracker_links")
}

model TrackerOfferSaleSignal {
  id                   String                   @id @default(cuid())
  offerId              String                   @map("offer_id")
  offer                TrackerOffer             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  dedupeKey            String                   @map("dedupe_key") @db.VarChar(64)
  platformOrderId      String?                  @map("platform_order_id") @db.VarChar(200)
  amountGross          Decimal                  @default(0) @map("amount_gross") @db.Decimal(14, 2)
  currency             String                   @default("BRL") @db.VarChar(8)
  paymentState         TrackerSalePaymentState  @map("payment_state")
  gclid                String?                  @db.VarChar(512)
  payloadSnapshot      Json?                    @map("payload_snapshot")
  sourceIp             String                   @default("") @map("source_ip") @db.VarChar(45)
  ipTrust              TrackerOfferIpTrust      @map("ip_trust")
  signatureValid       Boolean                  @default(false) @map("signature_valid")
  countedForRevenue    Boolean                  @default(true) @map("counted_for_revenue")
  googleOfflineSentAt  DateTime?                @map("google_offline_sent_at")
  googleOfflineError   String?                  @map("google_offline_error") @db.VarChar(500)
  /// Upsell / order bump inferido do postback (para regras de conversão).
  isUpsell             Boolean                  @default(false) @map("is_upsell")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversionDispatches TrackerConversionDispatch[]

  @@unique([offerId, dedupeKey])
  @@index([offerId, createdAt])
  @@map("tracker_offer_sale_signals")
}

// ============ ADS TRACKER — Módulo 08: Regras de conversão offline (Google Ads) ============

enum TrackerConversionEventKind {
  PURCHASE
  LEAD
  INITIATE_CHECKOUT
  HIGH_INTENT_LEAD
}

enum TrackerConversionUpsellMode {
  INCLUDE_ALL
  PRIMARY_ONLY
  UPSELL_ONLY
}

enum TrackerConversionValueMode {
  FULL_GROSS
  NET_AFTER_PLATFORM_FEE
  MICRO_ZERO
}

enum TrackerConversionDispatchStatus {
  QUEUED
  SENT
  SKIPPED_ORGANIC
  SKIPPED_FILTER
  FAILED
}

model TrackerConversionRule {
  id     String        @id @default(cuid())
  name   String        @db.VarChar(200)
  slug   String        @unique @db.VarChar(80)
  active Boolean       @default(true)
  /// Tipo lógico; só PURCHASE está ligado a sinais S2S de oferta nesta versão.
  eventKind TrackerConversionEventKind @map("event_kind")

  offerId String?      @map("offer_id")
  offer   TrackerOffer? @relation(fields: [offerId], references: [id], onDelete: Cascade)

  onlyApprovedPurchases Boolean @default(true) @map("only_approved_purchases")
  upsellMode            TrackerConversionUpsellMode @default(INCLUDE_ALL) @map("upsell_mode")

  valueMode                 TrackerConversionValueMode @default(FULL_GROSS) @map("value_mode")
  /// Percentagem da plataforma a descontar quando valueMode = NET_AFTER_PLATFORM_FEE (ex.: 9.9).
  platformFeePercent        Decimal?                 @map("platform_fee_percent") @db.Decimal(5, 2)
  /// 100 = valor completo (após modo); 0 = micro-conversão sem valor monetário relevante.
  conversionWeightPercent   Int                      @default(100) @map("conversion_weight_percent")

  /// Customer ID Google Ads (só dígitos, sem hífenes) onde existe a ação de conversão.
  googleAdsCustomerId       String?                  @map("google_ads_customer_id") @db.VarChar(32)
  /// ID numérico da Conversion Action (offline upload).
  googleConversionActionId  String?                  @map("google_conversion_action_id") @db.VarChar(32)
  /// Etiqueta / nome de referência (painel antigo ou notas operacionais).
  googleConversionLabel     String?                  @map("google_conversion_label") @db.VarChar(255)

  /// Atraso mínimo antes de tentar enviar (antifraude, reconciliação — não “simular humano”).
  delayMinutesBeforeSend Int @default(60) @map("delay_minutes_before_send")

  backendAction String @default("OFFLINE_GCLIC_UPLOAD") @map("backend_action") @db.VarChar(64)

  /// Reservado para conversão preditiva (requer métricas de tempo na página).
  earlySignalMinSecondsOnPage Int? @map("early_signal_min_seconds_on_page")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dispatches TrackerConversionDispatch[]

  @@index([active, eventKind])
  @@index([offerId])
  @@map("tracker_conversion_rules")
}

model TrackerConversionDispatch {
  id     String               @id @default(cuid())
  ruleId String               @map("rule_id")
  rule   TrackerConversionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  saleSignalId String?               @map("sale_signal_id")
  saleSignal   TrackerOfferSaleSignal? @relation(fields: [saleSignalId], references: [id], onDelete: Cascade)

  status TrackerConversionDispatchStatus @map("status")

  /// PAID_GCLID | ORGANIC_NO_GCLID — para monitor.
  matchKind String @map("match_kind") @db.VarChar(32)

  valueComputed Decimal? @map("value_computed") @db.Decimal(14, 2)
  currency      String   @default("BRL") @db.VarChar(8)

  scheduledFor  DateTime  @map("scheduled_for")
  processedAt   DateTime? @map("processed_at")
  errorMessage  String?   @map("error_message") @db.VarChar(500)
  gclidSnapshot String?   @map("gclid_snapshot") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ruleId, saleSignalId])
  @@index([status, scheduledFor])
  @@index([createdAt])
  @@map("tracker_conversion_dispatches")
}

// ============ ADS TRACKER — Módulo 06: Checkout (túnel de parâmetros / logs) ============

enum TrackerCheckoutParamMode {
  /// Encaminha todos os query params recebidos no /pay/... (exceto colisão com keys já fixas no alvo).
  PRESERVE_ALL_INBOUND
  /// Só chaves em forwardedParamKeys.
  ALLOWLIST_ONLY
}

enum TrackerCheckoutInitiationOutcome {
  REDIRECT_302
  OFFER_NOT_FOUND
  INVALID_CHECKOUT_URL
  TOKEN_EXPIRED
  TOKEN_EXHAUSTED
  OFFER_INACTIVE
}

/// Configuração de túnel de query por oferta (1:1).
model TrackerCheckoutSettings {
  id     String       @id @default(cuid())
  offerId String      @unique @map("offer_id")
  offer  TrackerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  forwardedParamKeys Json @map("forwarded_param_keys")
  paramMode          TrackerCheckoutParamMode @default(ALLOWLIST_ONLY) @map("param_mode")

  /// Links de um uso / TTL (anti-scraping básico). O caminho público é /pay/t/{token}.
  useEphemeralLinks   Boolean @default(false) @map("use_ephemeral_links")
  ephemeralTtlMinutes Int     @default(60) @map("ephemeral_ttl_minutes")
  ephemeralMaxUses    Int     @default(1) @map("ephemeral_max_uses")

  /// Atraso opcional (ms) sugerido para scripts de terceiros no browser — cumprir políticas das plataformas.
  pixelBackupDelayMs Int? @map("pixel_backup_delay_ms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tracker_checkout_settings")
}

model TrackerCheckoutInitiation {
  id     String        @id @default(cuid())
  offerId String?      @map("offer_id")
  offer  TrackerOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  sourceIp  String  @map("source_ip") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(512)
  referer   String? @map("referer") @db.VarChar(2000)

  fromGoogleAds Boolean @map("from_google_ads")

  /// Snapshot limitado dos query params do pedido ao /pay.
  querySnapshot Json? @map("query_snapshot")

  outcome TrackerCheckoutInitiationOutcome @map("outcome")

  viaEphemeralToken Boolean @default(false) @map("via_ephemeral_token")
  paySlugOrToken    String? @map("pay_slug_or_token") @db.VarChar(96)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([offerId, createdAt])
  @@map("tracker_checkout_initiations")
}

model TrackerCheckoutAccessToken {
  id      String       @id @default(cuid())
  offerId String       @map("offer_id")
  offer   TrackerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  token     String   @unique @db.VarChar(32)
  expiresAt DateTime @map("expires_at")
  useCount  Int      @default(0) @map("use_count")
  maxUses   Int      @default(1) @map("max_uses")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([offerId])
  @@index([token, expiresAt])
  @@map("tracker_checkout_access_tokens")
}

// ============ ADS TRACKER — Módulo 07: Fontes de tráfego (parâmetros / URL builder) ============

enum TrackerTrafficSourceStatus {
  ACTIVE
  PAUSED
}

/// Dicionário de parâmetros por rede (ex.: Google Ads) + parâmetros globais para o gerador de URLs.
model TrackerTrafficSource {
  id          String                       @id @default(cuid())
  slug        String                       @unique @db.VarChar(64)
  name        String                       @db.VarChar(200)
  status      TrackerTrafficSourceStatus   @default(ACTIVE)
  /// Identificador de UI (google_ads, meta, tiktok, custom, …).
  networkKind String                       @map("network_kind") @db.VarChar(32)
  builtIn     Boolean                      @default(false) @map("built_in")
  /// Blueprint: clickIdParam, assumeAutoTagging, utm{}, customPairs[{key,value}] (ValueTrack entre chaves).
  paramBlueprint Json @map("param_blueprint")
  /// Pares fixos adicionados a todas as URLs geradas desta fonte.
  globalParams     Json @map("global_params")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("tracker_traffic_sources")
}

// ============ WAR ROOM OS — Módulo 07: Live Proof Labs (ofertas validadas / cemitério) ============

enum LiveProofLabCaseStatus {
  DRAFT
  /// Equipa a testar — pode aparecer na área do mentorado se publicado
  EM_TESTE
  /// Oferta com métricas que fecharam positivo
  VALIDADA
  /// Cemitério / teste que não funcionou
  REPROVADA
  /// Operação a escalar na banca interna
  EM_ESCALA
}

enum LiveProofLabInsightKind {
  AUDIO
  VIDEO
}

/// Caso publicado na área do mentorado: prova de operação interna + opção de replicar criativo/VSL.
model LiveProofLabCase {
  id                     String                 @id @default(cuid())
  slug                   String                 @unique @db.VarChar(96)
  status                 LiveProofLabCaseStatus @default(DRAFT)
  title                  String                 @db.VarChar(200)
  productLabel           String                 @map("product_label") @db.VarChar(200)
  nicheLabel             String                 @map("niche_label") @db.VarChar(120)
  headline               String?                @db.VarChar(320)
  summary                String?                @db.Text
  /// Oferta tracker interna (receita S2S em tempo real no dossiê)
  internalTrackerOfferId String?                @unique @map("internal_tracker_offer_id")
  internalTrackerOffer   TrackerOffer?          @relation(fields: [internalTrackerOfferId], references: [id], onDelete: SetNull)
  creativeTemplateId     String?                @map("creative_template_id")
  creativeTemplate       CreativeVaultTemplate? @relation(fields: [creativeTemplateId], references: [id], onDelete: SetNull)
  /// URL de checkout sugerida ao mentorado (replicar / shield)
  suggestedCheckoutUrl   String?                @map("suggested_checkout_url") @db.VarChar(2000)
  defaultOfferPlatform   TrackerOfferPlatform?  @map("default_offer_platform")
  vslScriptNotes         String?                @map("vsl_script_notes") @db.Text
  analysisText           String?                @map("analysis_text") @db.Text
  cpaIdealBrl            Decimal?               @map("cpa_ideal_brl") @db.Decimal(12, 2)
  scaleBudgetHintBrl     Decimal?               @map("scale_budget_hint_brl") @db.Decimal(14, 2)
  /// Gasto real 24h/7d (snapshot / webhook / Sheets)
  spend24hBrl            Decimal?               @map("spend_24h_brl") @db.Decimal(14, 2)
  spend7dBrl             Decimal?               @map("spend_7d_brl") @db.Decimal(14, 2)
  /// Métricas sincronizadas (webhook interno / equipa)
  gastoTotalBrl          Decimal?               @map("gasto_total_brl") @db.Decimal(14, 2)
  cpaMedioBrl            Decimal?               @map("cpa_medio_brl") @db.Decimal(12, 4)
  roiLiquidoPercent      Decimal?               @map("roi_liquido_percent") @db.Decimal(10, 4)
  volumeVendas           Int?                   @map("volume_vendas")
  metricsSyncedAt        DateTime?              @map("metrics_synced_at")
  graveyardReason        String?                @map("graveyard_reason") @db.Text
  graveyardLossBrl       Decimal?               @map("graveyard_loss_brl") @db.Decimal(14, 2)
  sortOrder              Int                    @default(0) @map("sort_order")
  validatedAt            DateTime?              @map("validated_at")
  publishedToClients     Boolean                @default(false) @map("published_to_clients")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  screenshots LiveProofLabScreenshot[]
  insights    LiveProofLabInsight[]
  replicates       LiveProofLabReplicateLog[]
  spendDays        LiveProofLabSpendDay[]
  templateUnlocks  LiveProofLabTemplateUnlock[]

  @@index([status, publishedToClients, sortOrder])
  @@map("live_proof_lab_cases")
}

/// Série diária de gasto real (Skin in the Game) — preenchida via webhook ou admin
model LiveProofLabSpendDay {
  id        String           @id @default(cuid())
  caseId    String           @map("case_id")
  case      LiveProofLabCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  day       DateTime         @map("day") @db.Date
  amountBrl Decimal          @map("amount_brl") @db.Decimal(14, 2)

  @@unique([caseId, day])
  @@index([caseId])
  @@map("live_proof_lab_spend_days")
}

/// Criativo desbloqueado no Creative Vault após “Copiar operação”
model LiveProofLabTemplateUnlock {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  client     ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  templateId String   @map("template_id")
  template   CreativeVaultTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  caseId     String   @map("case_id")
  case       LiveProofLabCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([clientId, templateId])
  @@index([caseId])
  @@map("live_proof_lab_template_unlocks")
}

model LiveProofLabScreenshot {
  id          String           @id @default(cuid())
  caseId      String           @map("case_id")
  case        LiveProofLabCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  imageUrl    String           @map("image_url") @db.VarChar(2000)
  caption     String?          @db.VarChar(300)
  /// Momento do print (dashboard)
  capturedAt  DateTime?        @map("captured_at")
  sortOrder   Int              @default(0) @map("sort_order")

  @@index([caseId, sortOrder])
  @@map("live_proof_lab_screenshots")
}

model LiveProofLabInsight {
  id        String                  @id @default(cuid())
  caseId    String                  @map("case_id")
  case      LiveProofLabCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind      LiveProofLabInsightKind
  mediaUrl  String                  @map("media_url") @db.VarChar(2000)
  title     String?                 @db.VarChar(200)
  sortOrder Int                     @default(0) @map("sort_order")

  @@index([caseId, sortOrder])
  @@map("live_proof_lab_insights")
}

model LiveProofLabReplicateLog {
  id        String            @id @default(cuid())
  caseId    String            @map("case_id")
  case      LiveProofLabCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId  String            @map("client_id")
  client    ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobId     String?           @map("job_id")
  job       CreativeAgencyJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@index([caseId])
  @@map("live_proof_lab_replicate_logs")
}

// ──────────────────────────────────────────────────────────────────────────────
// MÓDULO DE INVENTÁRIO — Gestão de Estoque do Gerente de Produção
// ──────────────────────────────────────────────────────────────────────────────

enum InventoryCheckStatus {
  ABERTO
  FINALIZADO
  CANCELADO
}

enum InventoryItemCategory {
  CONTA_PRODUCAO
  EMAIL_GMAIL
  CNPJ
  RG_DOCUMENTO
  PROXY
  PERFIL_PAGAMENTO
  HARDWARE
  OUTRO
}

enum InventoryItemReason {
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  QUEBRA_TECNICA
  ERRO_LANCAMENTO
  PERDA_EXTRAVIO
  ENTRADA_FORNECEDOR
}

/// Sessão de inventário (cíclico por categoria ou geral)
model InventoryCheck {
  id              String                @id @default(cuid())
  title           String                @db.VarChar(200)
  category        InventoryItemCategory?
  status          InventoryCheckStatus  @default(ABERTO)
  managerId       String                @map("manager_id")
  manager         User                  @relation(fields: [managerId], references: [id])
  notes           String?               @db.Text
  /// Impacto financeiro total calculado no fechamento
  totalValueImpact Decimal?             @map("total_value_impact") @db.Decimal(14, 2)
  /// Percentual máximo de divergência encontrado (para alerta CEO)
  maxDivergencePct Decimal?             @map("max_divergence_pct") @db.Decimal(6, 2)
  /// Disparou alerta de auditoria para o CEO?
  ceoAlertTriggered Boolean             @default(false) @map("ceo_alert_triggered")
  finalizedAt     DateTime?             @map("finalized_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  items           InventoryItem[]

  @@index([managerId, status])
  @@index([createdAt])
  @@map("inventory_checks")
}

/// Item dentro de uma sessão de inventário
model InventoryItem {
  id            String                @id @default(cuid())
  checkId       String                @map("check_id")
  check         InventoryCheck        @relation(fields: [checkId], references: [id], onDelete: Cascade)
  itemName      String                @db.VarChar(300)
  itemCategory  InventoryItemCategory @map("item_category")
  /// Saldo no sistema no momento da abertura do inventário
  systemStock   Int                   @map("system_stock")
  /// Quantidade física contada pelo gerente (null = ainda não conferido)
  physicalStock Int?                  @map("physical_stock")
  /// Diferença: physicalStock - systemStock (calculado)
  difference    Int?
  /// Custo unitário no momento da contagem (para impacto financeiro)
  unitCost      Decimal?              @map("unit_cost") @db.Decimal(12, 2)
  /// Motivo obrigatório quando há divergência
  reason        InventoryItemReason?
  notes         String?               @db.VarChar(500)
  /// Classificação ABC automática: A = alto valor/rotatividade, B = médio, C = baixo
  abcClass      String?               @map("abc_class") @db.Char(1)
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([checkId])
  @@index([itemCategory])
  @@map("inventory_items")
}

/// Log de movimentação de estoque gerado pelo fechamento de inventário
model StockMovement {
  id          String                @id @default(cuid())
  checkId     String?               @map("check_id")
  itemName    String                @db.VarChar(300)
  category    InventoryItemCategory
  quantity    Int
  /// ENTRADA_INVENTARIO | SAIDA_INVENTARIO
  movType     String                @map("mov_type") @db.VarChar(30)
  reason      InventoryItemReason?
  unitCost    Decimal?              @map("unit_cost") @db.Decimal(12, 2)
  managerId   String                @map("manager_id")
  manager     User                  @relation(fields: [managerId], references: [id])
  createdAt   DateTime              @default(now()) @map("created_at")

  @@index([managerId, createdAt])
  @@index([category, createdAt])
  @@map("stock_movements")
}

// ──────────────────────────────────────────────────────────────────────────────
// MÓDULO DE SUPPLY CHAIN / WHITE LABEL — Compras, Fornecedores e Ativos
// Arquitetura Double-Blind: Fornecedor visível apenas para PURCHASING/ADMIN
// ──────────────────────────────────────────────────────────────────────────────

enum AssetCategory {
  CONTAS    // Contas de anúncio (Meta, Google, TikTok)
  PERFIS    // Perfis de usuário (aquecimento)
  BM        // Business Managers
  PROXIES   // Proxies dedicados / residenciais
  SOFTWARE  // Ferramentas, licenças, SaaS
  INFRA     // Servidores, VPS, chips
  HARDWARE  // Dispositivos físicos
  OUTROS
}

enum AssetStatus {
  AVAILABLE        // Disponível no estoque
  QUARANTINE       // Em quarentena — aguarda período de estabilidade
  SOLD             // Vendido — aguarda liquidação financeira do fornecedor
  AWAITING_VENDOR  // Aguardando envio do fornecedor
  RECEIVED         // Recebido em Compras
  TRIAGEM          // Em triagem / validação
  DELIVERED        // Enviado ao cliente
  DEAD             // Dead Switch — baixado por falha antes da entrega
}

enum PurchaseOrderStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELED
}

/// Cadastro de Fornecedores (suporta até 1.000+ com índices)
model Vendor {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(200)
  taxId        String?  @unique @map("tax_id") @db.VarChar(30)
  /// JSON: { email, whatsapp, telegram, country, website }
  contactInfo  Json?    @map("contact_info")
  rating       Int      @default(5)             // 1-10
  paymentTerms String?  @map("payment_terms") @db.VarChar(200)
  category     String   @db.VarChar(50)         // CONTAS | INFRA | SOFTWARE | PROXIES
  active       Boolean  @default(true)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assets         Asset[]
  purchaseOrders PurchaseOrder[]

  @@index([category, active])
  @@map("vendors")
}

/// Sequência para geração de IDs únicos Ads Ativos por categoria
model AssetCounter {
  category String @id @db.VarChar(20)
  lastSeq  Int    @default(0) @map("last_seq")

  @@map("asset_counters")
}

/// Ativo individual — cada unidade física/digital rastreada
model Asset {
  id          String        @id @default(cuid())
  /// ID exclusivo Ads Ativos: AA-CONT-000001
  adsId       String        @unique @map("ads_id") @db.VarChar(30)
  category    AssetCategory
  subCategory String?       @map("sub_category") @db.VarChar(100)
  status      AssetStatus   @default(AVAILABLE)

  // ── Dados do Fornecedor (visíveis apenas para PURCHASING / ADMIN) ───────────
  vendorId    String        @map("vendor_id")
  costPrice   Decimal       @map("cost_price") @db.Decimal(10, 2)
  vendorRef   String?       @map("vendor_ref") @db.VarChar(100)
  /// Credenciais/tokens brutos — nunca expostos fora de PURCHASING
  rawData     Json?         @map("raw_data")

  // ── Identidade Ads Ativos (visível comercialmente) ───────────────────────
  salePrice   Decimal       @map("sale_price") @db.Decimal(10, 2)
  displayName String        @map("display_name") @db.VarChar(200)
  description String?       @db.Text
  /// Especificações mascaradas (sem referência a fornecedor)
  specs       Json?
  /// Tags separadas por vírgula: warm-up,gold,proxy-dedicado
  tags        String?       @db.VarChar(500)

  // ── Vínculos ───────────────────────────────────────────────────────────────
  purchaseOrderId String?   @map("purchase_order_id")

  // ── Auditoria de Ciclo de Vida ─────────────────────────────────────────────
  receivedAt  DateTime?     @map("received_at")
  soldAt      DateTime?     @map("sold_at")
  deliveredAt DateTime?     @map("delivered_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  movements     AssetMovement[]

  @@index([status])
  @@index([vendorId])
  @@index([category, status])
  @@map("assets")
}

/// Histórico de mudança de estado de cada ativo (audit trail completo)
model AssetMovement {
  id         String       @id @default(cuid())
  assetId    String       @map("asset_id")
  fromStatus AssetStatus? @map("from_status")
  toStatus   AssetStatus  @map("to_status")
  reason     String?      @db.VarChar(500)
  userId     String?      @map("user_id")
  createdAt  DateTime     @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@map("asset_movements")
}

/// Ordem de Compra para fornecedor — gera alerta financeiro de pagamento pendente
model PurchaseOrder {
  id          String              @id @default(cuid())
  vendorId    String              @map("vendor_id")
  totalAmount Decimal             @map("total_amount") @db.Decimal(12, 2)
  paidAmount  Decimal             @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status      PurchaseOrderStatus @default(PENDING)
  paymentDue  DateTime?           @map("payment_due")
  paidAt      DateTime?           @map("paid_at")
  notes       String?             @db.Text
  createdBy   String?             @map("created_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  vendor        Vendor  @relation(fields: [vendorId], references: [id])
  createdByUser User?   @relation("PurchaseOrderCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  assets        Asset[]

  @@index([vendorId, status])
  @@map("purchase_orders")
}
