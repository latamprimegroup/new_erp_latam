// ============ MÓDULO DE ENTREGAS (ADS ATIVOS) ============

enum DeliveryGroupStatus {
  AGUARDANDO_INICIO
  EM_ANDAMENTO
  PARCIALMENTE_ENTREGUE
  FINALIZADA
  ATRASADA
  EM_REPOSICAO
  CANCELADA
}

/// Gargalo operacional visível no Delivery Tracker (Plug & Play)
enum DeliveryOperationalBottleneck {
  AGUARDANDO_PRODUCAO
  AGUARDANDO_URL
  PRODUCAO_EM_ANDAMENTO
  AGUARDANDO_CLIENTE
  EM_VALIDACAO
  NENHUM
}

enum DeliveryAccountType {
  USD
  BRL
}

enum DeliveryPaymentType {
  AUTOMATICO
  MANUAL
}

model DeliveryGroup {
  id                    String              @id @default(cuid())
  groupNumber           String              @unique @map("group_number")  // GR-0001
  lastUpdatedAt         DateTime?           @map("last_updated_at") // Última atualização operacional (gerado automaticamente)
  clientId              String              @map("client_id")
  client                ClientProfile       @relation(fields: [clientId], references: [id])
  orderId               String?             @map("order_id")
  order                 Order?              @relation(fields: [orderId], references: [id])
  whatsappGroupLink     String              @unique @map("whatsapp_group_link")
  accountType           DeliveryAccountType @map("account_type")
  quantityContracted    Int                 @map("quantity_contracted")
  quantityDelivered     Int                 @default(0) @map("quantity_delivered")
  currency              String              @default("BRL")
  paymentType           DeliveryPaymentType @map("payment_type")
  estimatedTimeHours    Int?                @map("estimated_time_hours")
  expectedCompletionAt  DateTime?           @map("expected_completion_at")
  status                DeliveryGroupStatus @default(AGUARDANDO_INICIO)
  completedAt           DateTime?           @map("completed_at")
  responsibleId         String              @map("responsible_id")
  responsible           User                @relation(fields: [responsibleId], references: [id])
  groupCreatedAt        DateTime            @default(now()) @map("group_created_at")
  saleDate              DateTime?           @map("sale_date")
  /// Notas rápidas para produção (ex.: aguardando URL do cliente)
  observacoesProducao   String?             @map("observacoes_producao") @db.Text
  /// Semáforo de gargalo no tracker
  operationalBottleneck DeliveryOperationalBottleneck @default(AGUARDANDO_PRODUCAO) @map("operational_bottleneck")
  /// Marcação urgente (filtro rápido)
  trackerUrgent         Boolean             @default(false) @map("tracker_urgent")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  repositions           DeliveryReposition[]
  returns               DeliveryReturn[]
  financialEntries      FinancialEntry[]
  logs                  DeliveryGroupLog[]
  productionG2Items    ProductionG2[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("delivery_groups")
}

enum RepositionReason {
  BLOQUEIO
  LIMITE_GASTO
  ERRO_ESTRUTURAL
  PROBLEMA_PERFIL
  OUTRO
}

enum RepositionStatus {
  SOLICITADA
  APROVADA
  NEGADA
  CONCLUIDA
}

model DeliveryReposition {
  id            String          @id @default(cuid())
  deliveryId    String          @map("delivery_id")
  delivery      DeliveryGroup   @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  quantity      Int
  reason        RepositionReason
  reasonOther   String?         @map("reason_other") @db.Text
  status        RepositionStatus @default(SOLICITADA)
  requestedAt   DateTime        @default(now()) @map("requested_at")
  analystId     String?         @map("analyst_id")
  analyst       User?           @relation(fields: [analystId], references: [id])
  resolvedAt    DateTime?       @map("resolved_at")
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@index([deliveryId])
  @@index([status])
  @@map("delivery_repositions")
}

// Devolução de contas (impacto financeiro, crédito, ajuste LTV)
model DeliveryReturn {
  id            String   @id @default(cuid())
  deliveryId    String   @map("delivery_id")
  delivery      DeliveryGroup @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  quantity      Int      // Quantidade devolvida
  reason        String?  @db.Text
  status        String   @default("REGISTRADA") // REGISTRADA, CREDITO_APLICADO
  valueAdjusted Decimal? @map("value_adjusted") @db.Decimal(12, 2) // Valor do crédito/ajuste
  createdAt     DateTime @default(now()) @map("created_at")
  createdById   String?  @map("created_by_id")

  @@index([deliveryId])
  @@map("delivery_returns")
}

model DeliveryGroupLog {
  id          String   @id @default(cuid())
  deliveryId  String   @map("delivery_id")
  delivery    DeliveryGroup @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?  @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([deliveryId])
  @@index([createdAt])
  @@map("delivery_group_logs")
}

// ============ FINANCEIRO ============

enum FinancialType {
  INCOME
  EXPENSE
}

/// Status do lançamento financeiro (contas a pagar/receber)
enum FinEntryStatus {
  PENDING   // Pendente — a vencer
  PAID      // Pago / Recebido
  CANCELED  // Cancelado
  OVERDUE   // Em atraso (dueDate < agora e não pago)
}

/// Método de pagamento
enum FinPaymentMethod {
  PIX
  BOLETO
  CARTAO_CREDITO
  CARTAO_DEBITO
  TED
  DOC
  CASH
  CRIPTO
  OUTRO
}

/// Carteira / conta bancária da empresa
model FinWallet {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(120)   // "Banco Inter Corrente", "Stone PJ", "Wise USD"
  bankName    String?  @map("bank_name") @db.VarChar(100)
  /// CHECKING | SAVINGS | DIGITAL | CREDIT | CRIPTO
  accountType String   @default("CHECKING") @map("account_type") @db.VarChar(30)
  currency    String   @default("BRL") @db.VarChar(10)
  /// Saldo atual (atualizado manualmente ou via conciliação)
  balance     Decimal  @default(0) @db.Decimal(16, 4)
  active      Boolean  @default(true)
  icon        String?  @db.VarChar(10)    // emoji ex: 🏦 💳 ₿
  color       String?  @db.VarChar(20)    // ex: #00B8D9
  notes       String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  entries     FinancialEntry[]
  nfes        FinNfe[]

  @@index([active])
  @@map("fin_wallets")
}

/// Nota Fiscal de Serviço (NFS-e) — integração FocusNFe / e-Notas
model FinNfe {
  id          String          @id @default(cuid())
  entryId     String?         @unique @map("entry_id")
  entry       FinancialEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  walletId    String?         @map("wallet_id")
  wallet      FinWallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)
  nfeNumber   String?         @map("nfe_number") @db.VarChar(50)
  series      String?         @db.VarChar(5)
  /// PENDENTE | EMITIDA | CANCELADA | ERRO
  nfeStatus   String          @default("PENDENTE") @map("nfe_status") @db.VarChar(20)
  issueDate   DateTime?       @map("issue_date")
  totalAmount Decimal?        @map("total_amount") @db.Decimal(14, 2)
  serviceDesc String?         @map("service_desc") @db.VarChar(500)
  clientCnpj  String?         @map("client_cnpj") @db.VarChar(20)
  clientName  String?         @map("client_name") @db.VarChar(200)
  /// ID retornado pelo FocusNFe / e-Notas
  externalId  String?         @map("external_id") @db.VarChar(100)
  pdfUrl      String?         @map("pdf_url") @db.VarChar(2000)
  xmlUrl      String?         @map("xml_url") @db.VarChar(2000)
  notes       String?         @db.VarChar(500)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt      @map("updated_at")

  @@index([nfeStatus])
  @@index([issueDate])
  @@index([clientCnpj])
  @@map("fin_nfes")
}

model FinancialCategory {
  id       String   @id @default(cuid())
  name     String
  type     FinancialType
  active   Boolean  @default(true)
  entries  FinancialEntry[]
}

model FinancialEntry {
  id             String            @id @default(cuid())
  type           FinancialType
  category       String
  categoryId     String?           @map("category_id")
  financialCategory FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter     String?           @map("cost_center")
  value          Decimal           @db.Decimal(12, 2)
  currency       String            @default("BRL")
  /// Data de competência (quando ocorreu / foi lançado)
  date           DateTime
  /// Vencimento — para contas a pagar/receber
  dueDate        DateTime?         @map("due_date")
  /// Data efetiva do pagamento/recebimento
  paymentDate    DateTime?         @map("payment_date")
  /// Status do lançamento — PAID é o default (retrocompatível com lançamentos antigos)
  entryStatus    FinEntryStatus    @default(PAID) @map("entry_status")
  /// Forma de pagamento
  paymentMethod  FinPaymentMethod? @map("payment_method")
  /// Carteira/banco associado
  walletId       String?           @map("wallet_id")
  wallet         FinWallet?        @relation(fields: [walletId], references: [id], onDelete: SetNull)
  orderId        String?           @map("order_id")
  order          Order?            @relation(fields: [orderId], references: [id])
  deliveryGroupId String?          @map("delivery_group_id")
  deliveryGroup  DeliveryGroup?    @relation(fields: [deliveryGroupId], references: [id])
  netProfit      Decimal?          @map("net_profit") @db.Decimal(12, 2)
  description    String?           @db.Text
  reconciled     Boolean           @default(false) @map("reconciled")
  createdAt      DateTime          @default(now()) @map("created_at")
  nfe            FinNfe?

  @@index([date])
  @@index([dueDate])
  @@index([entryStatus])
  @@index([walletId])
  @@index([orderId])
  @@index([deliveryGroupId])
}

// ============ VAULT INTELLIGENCE (LEDGER, CHARGEBACK, CMV, WALLET) ============

/// Lançamento de razão (partidas dobradas — débito = crédito por journal)
model VaultLedgerJournal {
  id          String   @id @default(cuid())
  occurredAt  DateTime @map("occurred_at")
  memo        String?  @db.VarChar(500)
  source      String   @db.VarChar(64) // ORDER_PAID, GATEWAY_SETTLEMENT, PAYOUT_PROVISION, CMV, CHARGEBACK, WALLET, MANUAL
  sourceId    String?  @map("source_id") @db.VarChar(64)
  createdById String?  @map("created_by_id")
  lines       VaultLedgerLine[]

  @@index([occurredAt])
  @@index([source, sourceId])
  @@map("vault_ledger_journals")
}

model VaultLedgerLine {
  id        String             @id @default(cuid())
  journalId String             @map("journal_id")
  journal   VaultLedgerJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account   String             @db.VarChar(48) // AR, REVENUE, GATEWAY_FEE, COGS, PAYOUT_PROVISION, CASH, CLIENT_WALLET, CHARGEBACK_LOSS
  debit     Decimal            @default(0) @db.Decimal(16, 4)
  credit    Decimal            @default(0) @db.Decimal(16, 4)
  meta      Json?

  @@index([journalId])
  @@map("vault_ledger_lines")
}

model ChargebackRecord {
  id                      String   @id @default(cuid())
  orderId                 String   @map("order_id")
  order                   Order    @relation(fields: [orderId], references: [id])
  amount                  Decimal  @db.Decimal(14, 4)
  gatewayRef              String?  @map("gateway_ref") @db.VarChar(120)
  notes                   String?  @db.Text
  status                  String   @default("OPEN") @db.VarChar(24) // OPEN, ASSETS_FLAGGED, CLOSED
  affectedStockAccountIds Json?    @map("affected_stock_account_ids")
  createdById             String?  @map("created_by_id")
  createdBy               User?    @relation("ChargebackCreatedBy", fields: [createdById], references: [id])
  createdAt               DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([createdAt])
  @@map("chargeback_records")
}

/// Crédito pré-pago (baleias) — saldo = último balanceAfter ou soma auditada
model ClientWalletLedger {
  id           String        @id @default(cuid())
  clientId     String        @map("client_id")
  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type         String        @db.VarChar(32) // DEPOSIT, DEBIT_ORDER, REFUND, ADJUSTMENT
  amount       Decimal       @db.Decimal(16, 4) // positivo aumenta saldo do cliente
  balanceAfter Decimal       @map("balance_after") @db.Decimal(16, 4)
  orderId      String?       @map("order_id")
  memo         String?       @db.VarChar(500)
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@map("client_wallet_ledger")
}

/// Lotes de insumos (domínio/proxy) — CMV por abatimento
model SupplyLot {
  id               String    @id @default(cuid())
  label            String    @db.VarChar(200)
  category         String    @db.VarChar(32) // DOMAIN, PROXY_RESIDENTIAL, PROXY_MOBILE, OTHER
  totalCost        Decimal   @map("total_cost") @db.Decimal(16, 4)
  unitsPurchased   Int       @map("units_purchased")
  unitsRemaining   Int       @map("units_remaining")
  unitCostComputed Decimal   @map("unit_cost_computed") @db.Decimal(16, 4)
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([category])
  @@map("supply_lots")
}

/// Ciclo operacional do colaborador (extrato + “liquidar ciclo”)
model ProducerVaultCycle {
  id                      String    @id @default(cuid())
  userId                  String    @map("user_id")
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  openedAt                DateTime  @map("opened_at")
  closedAt                DateTime? @map("closed_at")
  status                  String    @default("OPEN") @db.VarChar(16)
  provisionedProduction   Decimal   @default(0) @map("provisioned_production") @db.Decimal(16, 4)
  provisionedElite        Decimal   @default(0) @map("provisioned_elite") @db.Decimal(16, 4)
  unitsProductionCounted  Int       @default(0) @map("units_production_counted")
  unitsEliteCounted       Int       @default(0) @map("units_elite_counted")
  closedReportJson        Json?     @map("closed_report_json")

  @@index([userId, status])
  @@index([openedAt])
  @@map("producer_vault_cycles")
}

// ============ SAQUES ============

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  HELD
  FAILED
}

model Withdrawal {
  id          String          @id @default(cuid())
  userId      String?         @map("user_id") // Produtor que solicitou (saque por meta)
  user        User?           @relation(fields: [userId], references: [id])
  gateway     String
  accountId   String?         @map("account_id")
  value       Decimal         @db.Decimal(12, 2)
  fee         Decimal?        @db.Decimal(12, 2)
  netValue    Decimal         @map("net_value") @db.Decimal(12, 2)
  status      WithdrawalStatus @default(PENDING)
  dueDate     DateTime?       @map("due_date")
  risk        String?
  holdReason  String?         @map("hold_reason") @db.Text
  reconciled  Boolean         @default(false) @map("reconciled")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============ METAS E BÔNUS ============

model Goal {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  dailyTarget     Int      @map("daily_target")
  monthlyTarget   Int      @map("monthly_target")
  productionCurrent Int    @default(0) @map("production_current")
  bonus           Decimal? @db.Decimal(12, 2)
  /// Taxa mínima de aprovação no mês (0–100) para liberar qualityBonus; null = não aplicável
  minApprovalRatePercent Int?     @map("min_approval_rate_percent")
  qualityBonus          Decimal? @map("quality_bonus") @db.Decimal(12, 2)
  status          String   @default("active")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bonusReleases   BonusRelease[]

  @@index([userId, periodStart])
  @@index([status])
}

model BonusRelease {
  id        String   @id @default(cuid())
  goalId    String   @map("goal_id")
  goal      Goal     @relation(fields: [goalId], references: [id])
  value     Decimal  @db.Decimal(12, 2)
  status    String   @default("pending")
  releasedAt DateTime? @map("released_at")
  createdAt DateTime @default(now()) @map("created_at")
}

// Fechamento mensal do produtor: salário + valor por conta + bônus. Ao fechar, libera saque.
model ProducerMonthlyStatement {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  month            Int
  year             Int
  accountsApproved Int      @map("accounts_approved")
  baseSalary       Decimal  @map("base_salary") @db.Decimal(12, 2)
  perAccountTotal  Decimal  @map("per_account_total") @db.Decimal(12, 2)
  bonusTotal       Decimal  @map("bonus_total") @db.Decimal(12, 2)
  totalAmount      Decimal  @map("total_amount") @db.Decimal(12, 2)
  status           String   @default("PENDING") // PENDING, CLOSED (libera saque)
  closedAt         DateTime? @map("closed_at")
  closedById       String?   @map("closed_by_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([userId, month, year])
  @@map("producer_monthly_statements")
}

// ============ COTAÇÕES ============

model Quotation {
  id         String       @id @default(cuid())
  clientId   String       @map("client_id")
  client     ClientProfile @relation(fields: [clientId], references: [id])
  accountId  String       @map("account_id")
  account    StockAccount @relation(fields: [accountId], references: [id])
  status     String       @default("pending")
  message    String?      @db.Text
  createdAt  DateTime     @default(now()) @map("created_at")
}

// ============ OS CONTINGÊNCIA — FUNIL COMERCIAL & PIXEL / WEBHOOKS ============

enum LeadFunnelStep {
  STEP_1_CAPTURA
  STEP_2_WHATSAPP
  STEP_3_FOTO
  STEP_4_VALIDACAO
  STEP_5_QUALIFICACAO
  STEP_6_PROPOSTA
  STEP_7_CONVERSAO
}

model CommercialLead {
  id                   String         @id @default(cuid())
  name                 String?        @db.VarChar(200)
  phone                String?        @db.VarChar(30)
  whatsapp             String?        @db.VarChar(30)
  email                String?        @db.VarChar(200)
  photoPath            String?        @map("photo_path") @db.VarChar(500)
  funnelStep           LeadFunnelStep @default(STEP_1_CAPTURA) @map("funnel_step")
  validatedAt          DateTime?      @map("validated_at")
  assignedCommercialId String?        @map("assigned_commercial_id")
  assignedCommercial   User?          @relation("CommercialLeadAssignee", fields: [assignedCommercialId], references: [id])
  convertedClientId    String?        @map("converted_client_id")
  convertedClient      ClientProfile? @relation("LeadToClient", fields: [convertedClientId], references: [id])
  notes                String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([funnelStep, createdAt])
  @@index([assignedCommercialId])
  @@map("commercial_leads")
}

/// Central de Inteligência de Leads (Ecossistema 9D) — captura WordPress/Elementor + LTV
enum IntelligenceLeadStatus {
  NOVO
  QUENTE
  CLIENTE_ATIVO
  CHURN
}

model IntelligenceLead {
  id             String                @id @default(cuid())
  name           String                @map("nome") @db.VarChar(200)
  email          String                @unique @db.VarChar(254)
  whatsapp       String?               @db.VarChar(30)
  /// Último toque (atribuição multi-touch — quem ajudou a fechar)
  utmSource      String?               @map("utm_source") @db.VarChar(120)
  utmMedium      String?               @map("utm_medium") @db.VarChar(120)
  utmCampaign    String?               @map("utm_campaign") @db.VarChar(200)
  utmContent     String?               @map("utm_content") @db.VarChar(512)
  utmTerm        String?               @map("utm_term") @db.VarChar(200)
  /// Primeiro toque (quem apresentou a marca) — imutável após criação
  utmFirstSource   String?            @map("utm_first_source") @db.VarChar(120)
  utmFirstMedium   String?            @map("utm_first_medium") @db.VarChar(120)
  utmFirstCampaign String?            @map("utm_first_campaign") @db.VarChar(200)
  utmFirstContent  String?            @map("utm_first_content") @db.VarChar(512)
  utmFirstTerm     String?            @map("utm_first_term") @db.VarChar(200)
  status         IntelligenceLeadStatus @default(NOVO)
  lastPurchaseAt DateTime?             @map("data_ultima_compra")
  totalSales     Decimal               @default(0) @map("total_vendas") @db.Decimal(14, 2)
  /// Ticket médio (LTV ÷ compras) — atualizado no sync ERP
  averageTicketBrl Decimal?            @map("average_ticket_brl") @db.Decimal(12, 2)
  /// 0–100 confiança / qualidade do lead (webhook ou derivado do sync)
  trustScore     Int?                  @map("trust_score")
  /// Nº de pedidos pagos no ERP (sincronizado)
  purchaseCount  Int                   @default(0) @map("purchase_count")
  /// Último produto (texto do pedido) para mensagens / timeline
  lastProductName String?              @map("last_product_name") @db.VarChar(200)
  /// Identificador da LP de origem (webhook) — +10 pts no score
  landingPageKey String?               @map("landing_page_key") @db.VarChar(120)
  /// Intenção checkout (webhook) — +20 pts
  checkoutIntentAt DateTime?           @map("checkout_intent_at")
  /// Score 0–100 (regras: LP + checkout + histórico compra)
  engagementScore Int                 @default(0) @map("engagement_score")
  assignedCommercialId String?       @map("assigned_commercial_id")
  assignedCommercial   User?          @relation("IntelligenceLeadAssignee", fields: [assignedCommercialId], references: [id], onDelete: SetNull)
  /// Score 0–100: confiança “humano vs bot” (heurística)
  confidenceScore    Decimal         @default(50) @map("confidence_score") @db.Decimal(5, 2)
  /// Hash SHA-256 (IP|UA) — não armazenamos IP em claro
  fingerprintHash    String?         @map("fingerprint_hash") @db.VarChar(64)
  fingerprintUserAgent String?       @map("fingerprint_user_agent") @db.VarChar(512)
  /// Mesmo fingerprint noutro e-mail — alerta fraude / reembolso
  digitalFingerprintAlert Boolean   @default(false) @map("digital_fingerprint_alert")
  /// Tags: ["viu_vsl","abandonou_carrinho",...] (webhook + eventos)
  behaviorTags       Json?           @map("behavior_tags")
  /// Produtos já comprados (sync ERP) — base da esteira de upsell
  purchasedProductSlugs Json?        @map("purchased_product_slugs")
  /// Última interação comercial ou webhook (alerta de arrefecimento)
  lastInteractionAt  DateTime?     @map("last_interaction_at")
  /// CPA atribuído ao lead (custo de aquisição por conversão conhecida)
  cpaBrl           Decimal?        @map("cpa_brl") @db.Decimal(12, 2)
  /// Muita intenção em poucas horas sem compra — prioridade comercial
  hotStalledAlert  Boolean         @default(false) @map("hot_stalled_alert")
  /// Resumo IA (2 linhas) para o comercial — triagem virtual
  commercialAiBrief String?        @map("commercial_ai_brief") @db.VarChar(600)
  /// Carrinho/checkout iniciado sem aprovação a tempo — coluna “Resgate imediato”
  cartRescueImmediate Boolean     @default(false) @map("cart_rescue_immediate")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  events         IntelligenceLeadEvent[]
  checkoutSessions IntelligenceCheckoutSession[]

  @@index([status, createdAt])
  @@index([utmSource])
  @@index([trustScore])
  @@index([lastPurchaseAt])
  @@index([engagementScore])
  @@index([assignedCommercialId])
  @@index([fingerprintHash])
  @@index([digitalFingerprintAlert])
  @@index([hotStalledAlert])
  @@index([cartRescueImmediate])
  @@map("intelligence_leads")
}

/// Sessão de checkout (abandono / recuperação nativa)
enum IntelligenceCheckoutSessionStatus {
  STARTED
  PAYMENT_PENDING
  APPROVED
  ABANDONED
  RESCUE_IMMEDIATE
}

model IntelligenceCheckoutSession {
  id           String                           @id @default(cuid())
  email        String                           @db.VarChar(254)
  leadId       String?                          @map("lead_id")
  lead         IntelligenceLead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  status       IntelligenceCheckoutSessionStatus @default(STARTED)
  gatewayCode  String?                          @map("gateway_code") @db.VarChar(32)
  externalRef  String?                          @map("external_ref") @db.VarChar(200)
  valueBrl     Decimal?                         @map("value_brl") @db.Decimal(12, 2)
  startedAt    DateTime                         @default(now()) @map("started_at")
  updatedAt    DateTime                         @updatedAt @map("updated_at")
  approvedAt   DateTime?                        @map("approved_at")
  metadata     Json?

  @@index([email, status])
  @@index([status, startedAt])
  @@index([leadId])
  @@map("intelligence_checkout_sessions")
}

/// Contagem de webhooks de lead por minuto (saúde do tráfego)
model LeadIngestPulse {
  id          String   @id @default(cuid())
  minuteUtc   DateTime @map("minute_utc")
  ingestCount Int      @default(0) @map("ingest_count")

  @@unique([minuteUtc])
  @@index([minuteUtc])
  @@map("lead_ingest_pulses")
}

/// Evita spam de Telegram em alertas de tráfego
model TrafficAlertState {
  id                      String    @id @default("default")
  lastVolumeDropAlertAt   DateTime? @map("last_volume_drop_alert_at")
  lastSilenceAlertAt      DateTime? @map("last_silence_alert_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("traffic_alert_state")
}

/// Auditoria: quem viu/exportou dados comerciais sensíveis
model CommercialDataAuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @db.VarChar(24)
  action     String   @db.VarChar(64)
  entityType String   @map("entity_type") @db.VarChar(48)
  entityId   String?  @map("entity_id") @db.VarChar(191)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("commercial_data_audit_logs")
}

/// Gasto de mídia por UTM + mês (lucro real = LTV leads − spend)
model IntelligenceCampaignSpend {
  id           String   @id @default(cuid())
  utmSource    String   @map("utm_source") @db.VarChar(120)
