/// Pares RG do estoque (sorteio para ativos)
model AdsCoreRgStock {
  id         String               @id @default(cuid())
  frentePath String               @map("frente_path") @db.VarChar(500)
  versoPath  String               @map("verso_path") @db.VarChar(500)
