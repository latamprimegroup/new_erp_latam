  productionG2        ProductionG2?

  @@index([status, countryId])
  @@index([assignedToProducerId])
}

// ============ VENDAS E PEDIDOS ============

enum OrderStatus {
  QUOTE
  AWAITING_PAYMENT
  PENDING
  APPROVED
  REJECTED
  PAID
  IN_SEPARATION
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  clientId    String      @map("client_id")
  client      ClientProfile @relation(fields: [clientId], references: [id])
  country     String?
  product     String
  accountType String      @map("account_type")
  quantity    Int         @default(1)
  value       Decimal     @db.Decimal(12, 2)
  currency    String      @default("BRL")  // ISO 4217 para multi-moeda
  status      OrderStatus @default(AWAITING_PAYMENT)
  sellerId    String?     @map("seller_id")
  seller      User?       @relation("OrderSeller", fields: [sellerId], references: [id])
  pixKey      String?     @map("pix_key")
  pixQrCode   String?     @map("pix_qr_code") @db.Text
  interPixTxid String?    @unique @map("inter_pix_txid") @db.VarChar(120)
  interPixCopiaECola String? @map("inter_pix_copia_e_cola") @db.Text
  paymentDueAt DateTime? @map("payment_due_at")
  paidAt      DateTime?  @map("paid_at")
  /// Marcação única do bridge comercial (produção / P&amp;P / Telegram)
  commercialBridgeAt DateTime? @map("commercial_bridge_at")
  /// Markup comercial registrado (BRL) — opcional
  markupBrl   Decimal?   @map("markup_brl") @db.Decimal(12, 2)
  /// Cupom ou regra aplicada (ex.: AUTO_LOTE, código promocional)
  discountCode String?   @map("discount_code") @db.VarChar(64)
  /// Origem do pedido: MANUAL, TINTIM, COMMERCIAL, etc.
  orderSource  String    @default("MANUAL") @map("order_source") @db.VarChar(32)
  /// ID externo (ex.: venda Tintim)
  externalRef  String?   @map("external_ref") @db.VarChar(120)
  /// ADSPOWER_SHARE | SPREADSHEET | ERP_DIRECT
  deliveryMethod String?  @map("delivery_method") @db.VarChar(32)
  unitValue     Decimal?  @map("unit_value") @db.Decimal(12, 2)
  /// Câmbio BRL→USD no fechamento (matriz EUA / conciliação)
  fxRateBrlToUsd Decimal? @map("fx_rate_brl_usd") @db.Decimal(18, 8)
  /// BANK_TRANSFER | STRIPE | CRYPTO | LEAD_BANK | PIX | OUTRO
  paymentMethod String?  @map("payment_method") @db.VarChar(32)
  paymentReferenceMemo String? @map("payment_reference_memo") @db.VarChar(120)
  documentationUrl String? @map("documentation_url") @db.VarChar(500)
  /// Nicho declarado na venda (Black Hat, Health, iGaming…)
  saleUseNiche  String?  @map("sale_use_niche") @db.VarChar(48)
  /// Prazo de garantia em horas (24 / 48 / 168…)
  warrantyHours Int      @default(48) @map("warranty_hours")
  /// Calculado na confirmação do pagamento
  warrantyEndsAt DateTime? @map("warranty_ends_at")
  /// IDs externos colados na venda (Ads, BM, AdsPower) — JSON string[]
  deliveredAssetIdsJson Json? @map("delivered_asset_ids_json")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  items       OrderItem[]
  delivery    Delivery?
  deliveryGroups DeliveryGroup[]
  financialEntries FinancialEntry[]
  chargebacks ChargebackRecord[]
  replacementRequests AccountReplacementRequest[]

  @@index([clientId, status])
  @@index([paidAt])
  @@index([status, paidAt])
  @@index([createdAt])
}

model OrderItem {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id])
  accountId String      @map("account_id")
  account   StockAccount @relation(fields: [accountId], references: [id])
  quantity  Int         @default(1)
  deliveryProxyIp String? @map("delivery_proxy_ip") @db.VarChar(64)
  deliveryRegion  String? @map("delivery_region") @db.VarChar(64)
  /// ACTIVE | WARMED | DOC_SENT — snapshot na entrega
  accountStatusAtDelivery String? @map("account_status_at_delivery") @db.VarChar(24)
  adsPowerProfileId String? @map("adspower_profile_id") @db.VarChar(128)
}

// ============ ENTREGAS ============

enum DeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  DELAYED
}

model Delivery {
