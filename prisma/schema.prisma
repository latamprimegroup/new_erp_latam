// ============ ADS TRACKER — Traffic Shield (WAF / borda legítima; sem cloaking) ============

/// Configuração única (linha default). O ERP envia política ao edge via webhook; o edge aplica.
model TrafficShieldSettings {
  id                      String    @id @default("default")
  /// Sugestão enviada ao edge: bloquear ASNs típicos de datacenter (abuso/automação).
  blockDatacenterAsns     Boolean   @default(false) @map("block_datacenter_asns")
  /// Sugestão: exigir parâmetro de clique (ex. gclid) para classificar pedido — política no edge.
  requireClickIdParam     Boolean   @default(false) @map("require_click_id_param")
  /// Enviar lista de sinais de ambiente ao edge (o edge interpreta; não é “deteção de revisor”).
  pushEnvironmentHints    Boolean   @default(false) @map("push_environment_hints")
  /// Módulo 12: enviar ao edge listas de IPs/UA de ferramentas de espionagem.
  enableSpyToolBlocking   Boolean   @default(true) @map("enable_spy_tool_blocking")
  edgeWebhookUrl          String?   @map("edge_webhook_url") @db.VarChar(800)
  lastPushAt              DateTime? @map("last_push_at")
  lastPushOk              Boolean   @default(false) @map("last_push_ok")
