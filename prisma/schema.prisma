// Relatório mensal de gargalos
model BottleneckReport {
  id                String   @id @default(cuid())
  referenceDate     DateTime @map("reference_date")
  etapaMaisDemora   String?  @map("etapa_mais_demora")
  setorMaiorErro    String?  @map("setor_maior_erro")
  colaboradorRetrabalho String? @map("colaborador_retrabalho")
  tipoContaReprovacao   String? @map("tipo_conta_reprovacao")
  clienteMaiorReposicao String? @map("cliente_maior_reposicao")
  details           Json?
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([referenceDate])
  @@index([referenceDate])
  @@map("bottleneck_reports")
}

// ============ AUDITORIA ============

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  details    Json?
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entity, entityId])
}

// ============ FEEDBACK E MELHORIAS ============

enum SuggestionCategory {
  SYSTEM   // Melhoria do sistema (bugs, funções) -> backlog TI
  COMPANY  // Melhoria da empresa (processos, cultura) -> direção
}

model Suggestion {
  id          String            @id @default(cuid())
  category    SuggestionCategory
  title       String            @db.VarChar(200)
  description String            @db.Text
  userId      String?           @map("user_id") // Opcional: anônimo permitido para COMPANY
  user        User?             @relation(fields: [userId], references: [id])
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([category])
  @@index([createdAt])
  @@map("suggestions")
}
