model TrafficShieldAccessLog {
  id            String   @id @default(cuid())
  ip            String   @db.VarChar(45)
  country       String?  @db.VarChar(8)
  region        String?  @db.VarChar(80)
  userAgent     String?  @map("user_agent") @db.VarChar(600)
  referer       String?  @db.VarChar(1200)
  gclidPresent  Boolean  @default(false) @map("gclid_present")
  verdict       String   @db.VarChar(24)
  reason        String?  @db.VarChar(300)
  asn           String?  @db.VarChar(32)
  /// Contexto opcional (ex. campanha) — reportado pelo edge.
  contextKey    String?  @map("context_key") @db.VarChar(120)
  /// Valor bruto do gclid quando o edge o envia (atribuição / auditoria).
  gclid         String?  @db.VarChar(512)
  utmCampaign   String?  @map("utm_campaign") @db.VarChar(512)
  utmContent    String?  @map("utm_content") @db.VarChar(512)
  /// Rota/perfil operacional no edge: SAFE (pré-pagamento) vs MONEY (checkout).
  shieldProfile String?  @map("shield_profile") @db.VarChar(16)
  deviceCategory String? @map("device_category") @db.VarChar(24)
  browserFamily String?  @map("browser_family") @db.VarChar(64)
  /// Nome legível do ISP / rede (ex.: Google LLC), quando disponível.
  ispName       String?  @map("isp_name") @db.VarChar(200)
